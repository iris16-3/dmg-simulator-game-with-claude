  document.getElementById('result-msg').textContent=`All enemies defeated!\n\nTime: ${tt.toFixed(2)}s\nTotal DMG: ${totalDmg}`;
  openOv('ov-result');
}
function triggerLose(){
  if(bOver)return;bOver=true;
  const remaining=bEnemies.filter(e=>e.hp>0).length;
  const totalDmg=bLog.reduce((s,e)=>s+(e.totalBattleDmg||0),0);
  const box=document.getElementById('result-box');box.className='result-box lose';
  document.getElementById('result-title').textContent='✕ DEFEAT';
  document.getElementById('result-msg').textContent=`Time ran out!\n\n${remaining} enem${remaining===1?'y':'ies'} still alive.\nTotal DMG dealt: ${totalDmg}`;
  openOv('ov-result');
}

