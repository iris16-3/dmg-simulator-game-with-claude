      </div>
      <div class="cdb ${cdRem<=0?'rdy':'cool'}">${cdRem<=0?'CD READY':'CD '+cdRem.toFixed(2)+'s'}</div>
    </div>
    <div class="le-meta">
      <div class="mp dmg">DMG <span>${tdmg}</span>${isAdv&&entry.dmgType==='n'?advLine:''}</div>
      <div class="mp">CAST <span>${entry.castTime}s</span></div>
      <div class="mp">CD <span>${parseFloat(entry.cooldown)||0}s</span></div>
      <div class="mp">@ <span>${entry.timeAt.toFixed(2)}s</span></div>
    </div>
    ${entry.desc?`<div class="le-desc">${safe(entry.desc)}</div>`:''}
    ${dmtLabel}
    ${entry.effName?`<div class="le-eff">⬡ ${entry.effName}${entry.effDur?' — '+entry.effDur+'s':''}${entry.stacks?' [STACKS]':' [REFRESH]'}</div>`:''}
    <div class="le-acts">
      <button class="btn btn-ys btn-xs" onclick="reuseBtn(${entry.id},${isB})">USE AGAIN</button>
      <button class="btn btn-gh btn-xs" onclick="toggleEdit(${entry.id})">EDIT</button>
      <button class="btn btn-r btn-xs" onclick="deleteEntry(${entry.id},${isB})">DELETE</button>
    </div>
    <div class="ef" id="ef-${entry.id}">
      <div class="eg">
        <div class="full"><label>Character</label><select class="e-char">${charOpts}</select></div>
        <div class="full"><label>Ability Name</label><input type="text" class="e-nm" value="${entry.name}"></div>
        <div class="full"><label>Description</label><textarea class="e-desc">${safe(entry.desc||'')}</textarea></div>
        <div><label>Cast Time (s)</label><input type="number" class="e-cast" value="${entry.castTime}" step="0.1"></div>
        <div><label>Cooldown (s)</label><input type="number" class="e-cd" value="${entry.cooldown}" step="0.1"></div>
        <div><label>Damage Type</label><select class="e-dmt">${dmtOpts}</select></div>
