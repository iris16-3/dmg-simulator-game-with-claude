function makeCharCard(charObj,idx,dmg,totalDmg,castTime,mode){
  const isP=charObj.presetId!==null;
  const pct=totalDmg>0?((dmg/totalDmg)*100).toFixed(1):'0.0';
  const cdps=castTime>0?(dmg/castTime).toFixed(2):'0.00';
  const card=document.createElement('div');
  card.className='csc'+(isP?' preset':'');
  card.innerHTML=`
    <div class="cn">${charObj.name}${isP?`<span class="pbadge">#${charObj.presetId}</span>`:''}</div>
    <div class="cr"><span>DMG</span><strong>${dmg}</strong></div>
    <div class="cr"><span>%TEAM</span><strong>${pct}%</strong></div>
    <div class="cr"><span>CAST</span><strong>${castTime.toFixed(2)}s</strong></div>
    <div class="cr"><span>DPS</span><strong>${cdps}</strong></div>
    ${isP?'<div class="tap-hint">TAP FOR ABILITIES + RESOURCES</div>':''}
  `;
  // Resource bar
  if(isP){
    const pc=PC.find(p=>p.id===charObj.presetId);
    const ar=activeRes(pc);
    if(ar.length){
      const rb=document.createElement('div');rb.className='res-bar';
      ar.forEach(r=>{
        const cur=getRes(charObj.presetId,r.idx);
        const v=r.max!=null?`${cur}/${r.max}`:`${cur}`;
        rb.innerHTML+=`<div class="res-row"><span class="res-nm">${r.name}</span><span class="res-vl">${v}</span></div>`;
      });
      card.appendChild(rb);
    }
    card.onclick=()=>openPP(idx,mode);
  }
  return card;
}
function makeLogEntry(entry,log,isB,editFn,delFn,reuseFn,charList){
  const cdRem=getCDRem(entry,log);
  const tdmg=isB?(entry.totalBattleDmg||0):entryDmg(entry);
