      <div class="pc-head">
        <div class="pc-meta">
          <div class="ab-nm">${safe(ab.name)}${typeTag}${ab.canCrit?` <span style="color:#e74c3c;font-size:9px;border:1px solid #e74c3c;padding:1px 4px">CRIT</span>`:''}${ab.stunDmg?` <span style="color:#f39c12;font-size:9px;border:1px solid #f39c12;padding:1px 4px">STUN ${ab.stunDmg}</span>`:''}</div>
          <div class="ab-meta">DMG ${td} · CAST ${ab.castTime}s · CD ${ab.cooldown}s${ab.effName?' · ⬡ '+safe(ab.effName):''}</div>
          ${ab.desc?`<div class="ab-meta" style="font-style:italic;white-space:pre-wrap;word-break:break-word">${safe(ab.desc)}</div>`:''}
        </div>
        <div class="pc-acts">
          <button class="ua-vis-btn ${vis?'on':''}" onclick="toggleUAVisible(${ab.id})">${vis?'● SHOWN':'○ HIDDEN'}</button>
          <button class="btn btn-gh btn-xs" onclick="openUAModal(${ab.id})">EDIT</button>
          <button class="btn btn-r btn-xs" onclick="delUA(${ab.id})">DEL</button>
        </div>
      </div>
    `;
    el.appendChild(card);
  });
}

// ── UA DMG (uses char base stat if provided) ──
function abDmgUA(ab,charObj,varIdx){
  const cbs=charObj?.presetId?getBaseStat(charObj.presetId):0;
  const src=varIdx!=null&&varIdx>=0&&ab.variants?.[varIdx]?ab.variants[varIdx]:ab;
  const base=computeDmg(src.dmgFlat,src.stat,src.mult,src.b1,src.b2,cbs,src.dmg);
  const t=normDmgType(src.dmgType);
  if(t==='t'){if(!src.ticki||src.ticki<=0)return 0;return Math.floor(src.tickd/src.ticki)*base;}
  return base;
}

// ── UA PANEL (in-session) ──
function toggleUAPanel(){
  const panel=document.getElementById('ua-panel');
  const open=panel.classList.toggle('open');
  if(open)renderUAPanel();
}

function renderUAPanel(){
  const list=document.getElementById('ua-panel-list');list.innerHTML='';
  const visible=UA.filter(a=>a.visible!==false);
  if(!visible.length){
    list.innerHTML='<div class="pp-no-ab">No visible universal abilities. Toggle them on in setup.</div>';return;
  }
  uaVarState={};
  visible.forEach(ab=>{
    renderUAPanelRow(ab,list);
  });
}

function renderUAPanelRow(ab,listEl,replace){
  const src=ab;
  const td=abDmgUA(ab,null,null);
  const dmgType=normDmgType(src.dmgType);
  let typeTag='';
  if(dmgType==='d')typeTag=`<span style="color:#e67e22"> DELAYED</span>`;
  if(dmgType==='t'){const tk=src.ticki>0?Math.floor(src.tickd/src.ticki):0;typeTag=`<span style="color:#8e44ad"> DOT×${tk}</span>`;}
  const htTag=(src.hitType||'single')==='multi'?`<span style="color:#5dade2"> [MULTI]</span>`:`<span style="color:var(--muted)"> [SINGLE]</span>`;
  const row=document.createElement('div');row.className='ua-row';row.id='ua-row-'+ab.id;
  row.innerHTML=`
    <div class="ua-nm">${safe(src.name)}${typeTag}${htTag}${src.canCrit?`<span class="crit-tag">CRIT</span>`:''}${src.stunDmg?` <span style="color:#f39c12;font-size:9px;border:1px solid #f39c12;padding:1px 4px">STUN ${src.stunDmg}</span>`:''}</div>
    <div class="ua-meta">DMG ${td} · CAST ${src.castTime}s · CD ${src.cooldown}s${src.effName?' · ⬡ '+safe(src.effName):''}</div>
    ${src.desc?`<div class="ua-meta" style="font-style:italic;white-space:pre-wrap;word-break:break-word">${safe(src.desc)}</div>`:''}
    <div class="ua-acts">
      <button class="btn btn-sm" style="background:var(--green);color:#fff;border:none;font-weight:bold;font-family:var(--mono);font-size:10px;padding:4px 10px;letter-spacing:1px" onclick="openUACharPicker(${ab.id})">USE</button>
    </div>
  `;
  if(replace)replace.replaceWith(row);
  else listEl.appendChild(row);
}

function cycleUAVar(abId){
  const ab=UA.find(a=>a.id===abId);if(!ab)return;
  const total=1+(ab.variants||[]).length;
  const cur=uaVarState[abId]??-1;
  uaVarState[abId]=cur+1>=total-1?-1:cur+1;
  const old=document.getElementById('ua-row-'+abId);
  if(old){
    const tmp=document.createElement('div');
    renderUAPanelRow(ab,tmp);
    old.replaceWith(tmp.firstChild);
  }
}

function openUACharPicker(abId){
  pendingUA={abId};
  const list=document.getElementById('cp-list');list.innerHTML='';
  const isBattle=document.getElementById('battle').style.display==='flex';
  const charList=isBattle?bChars:chars;
  charList.forEach((c,i)=>{
    const btn=document.createElement('button');btn.className='cp-btn';
    btn.textContent=c.name+(c.presetId?` [#${c.presetId}]`:'');
    btn.onclick=()=>{closeOv('ov-cp');useUAAsChar(abId,i);};
    list.appendChild(btn);
  });
  openOv('ov-cp');
}

function useUAAsChar(abId,charIdx){
  const ab=UA.find(a=>a.id===abId);if(!ab)return;
  const isBattle=document.getElementById('battle').style.display==='flex';
  const charList=isBattle?bChars:chars;
  const charObj=charList[charIdx];
  const curLog=isBattle?bLog:cLog;
  const cdKey=`u${abId}_${charObj.name}`;
  const recent=curLog.find(e=>e.cdKey===cdKey);
  const cdRem=recent?getCDRem(recent,curLog):0;
  const srcWithMeta={...ab,abBaseId:abId,cdKey,varTag:null,isUniversal:true};
  const doOpen=()=>openLogModal(isBattle?'battle-reuse':'reuse',srcWithMeta,charIdx,srcWithMeta);
  if(cdRem>0)showAlert(ab.name+' has '+cdRem.toFixed(2)+'s on cooldown.',doOpen);
  else doOpen();
}

// Show/hide UA toggle button based on session state
function updateUAToggle(){
  const btn=document.getElementById('ua-toggle');if(!btn)return;
  const inSession=document.getElementById('app').style.display==='flex'||document.getElementById('battle').style.display==='flex';
  const hasVisible=UA.some(a=>a.visible!==false);
  btn.classList.toggle('visible',inSession&&hasVisible);
}

// ═══════════════════════════════════════════════
// NOTES
// ═══════════════════════════════════════════════
const NOTE_KEY='dmgcalc_notes';
let notes=[];         // [{id,name,content}]
let curNoteId=0;      // currently selected note id
let nextNoteId=1;

function loadNotes(){
  try{
    const r=localStorage.getItem(NOTE_KEY);
    if(r){const d=JSON.parse(r);notes=d.notes||[];nextNoteId=d.nextNoteId||1;}
  }catch(e){}
  // Ensure default note always exists
  if(!notes.find(n=>n.id===0))notes.unshift({id:0,name:'Notes',content:''});
  curNoteId=0;
}
function saveNotes(){
  try{localStorage.setItem(NOTE_KEY,JSON.stringify({notes,nextNoteId}));}catch(e){}
}
function toggleNotePanel(){
  const panel=document.getElementById('note-panel');
  const isOpen=panel.classList.toggle('open');
  if(isOpen)renderNotePanel();
}
function renderNotePanel(){
  const isSession=document.getElementById('app').style.display==='flex'||document.getElementById('battle').style.display==='flex';
  // Populate dropdown
  const sel=document.getElementById('note-sel');
  const prevId=parseInt(sel.value)||curNoteId;
  sel.innerHTML=notes.map(n=>`<option value="${n.id}" ${n.id===curNoteId?'selected':''}>${n.name}</option>`).join('');
  sel.value=curNoteId;
  // Name row: show only on setup screen for non-default notes
  const note=notes.find(n=>n.id===curNoteId)||notes[0];
  const nameRow=document.getElementById('note-name-row');
  const addRow=document.getElementById('note-add-row');
  const ta=document.getElementById('note-textarea');
  const delBtn=document.getElementById('note-del-btn');
  const nameInp=document.getElementById('note-name-inp');
  if(isSession){
    // Session mode: view only for non-default, editable for default
    nameRow.style.display='none';
    addRow.style.display='none';
    ta.value=note.content||'';
    ta.readOnly=(curNoteId!==0);
    if(curNoteId===0){
      ta.removeAttribute('readonly');
      ta.oninput=()=>{const n=notes.find(x=>x.id===0);if(n){n.content=ta.value;saveNotes();}};
    } else {
      ta.setAttribute('readonly','');
      ta.oninput=null;
    }
  } else {
    // Setup mode: full edit
    if(curNoteId===0){
      nameRow.style.display='none'; // default note has no rename/delete
    } else {
      nameRow.style.display='flex';
      nameInp.value=note.name;
      delBtn.style.display='';
    }
    addRow.style.display='flex';
    ta.removeAttribute('readonly');
    ta.value=note.content||'';
    ta.oninput=()=>{const n=notes.find(x=>x.id===curNoteId);if(n){n.content=ta.value;saveNotes();}};
    // Save name on blur
    nameInp.onblur=()=>{
      const n=notes.find(x=>x.id===curNoteId);
      if(n&&nameInp.value.trim()){n.name=nameInp.value.trim();saveNotes();renderNoteSel();}
    };
  }
}
function renderNoteSel(){
  const sel=document.getElementById('note-sel');
  sel.innerHTML=notes.map(n=>`<option value="${n.id}" ${n.id===curNoteId?'selected':''}>${n.name}</option>`).join('');
  sel.value=curNoteId;
}
function switchNote(){
  const sel=document.getElementById('note-sel');
  // Save current textarea content first
  const cur=notes.find(n=>n.id===curNoteId);
  if(cur)cur.content=document.getElementById('note-textarea').value;
  saveNotes();
  curNoteId=parseInt(sel.value);
  renderNotePanel();
}
function addNote(){
  const inp=document.getElementById('note-new-name');
  const name=inp.value.trim();
  if(!name)return;
  const id=nextNoteId++;
  notes.push({id,name,content:''});
  curNoteId=id;
  saveNotes();inp.value='';
  renderNotePanel();
}
function deleteNote(){
  if(curNoteId===0)return; // can't delete default
  if(!confirm('Delete this note?'))return;
  notes=notes.filter(n=>n.id!==curNoteId);
  curNoteId=0;
  saveNotes();renderNotePanel();
}

loadNotes();

// ═══════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════
document.getElementById('np-name').addEventListener('keydown',e=>{if(e.key==='Enter')addPC();});
document.getElementById('np-id').addEventListener('keydown',e=>{if(e.key==='Enter')addPC();});
loadUA();
renderLibrary();
renderUAList();
</script>
