function reuseEntry(id){
  const log=lmMode.startsWith('battle')?bLog:cLog;
  const e=log.find(x=>x.id===id);if(!e)return;
  const charList=lmMode.startsWith('battle')?bChars:chars;
  const ci=charList.findIndex(c=>c.name===e.char);
  const cdRem=getCDRem(e,log);
  if(cdRem>0)showAlert(e.name+' has '+cdRem.toFixed(2)+'s left on cooldown.',()=>openLogModal(lmMode.startsWith('battle')?'battle-reuse':'reuse',e,ci,null));
  else openLogModal(lmMode.startsWith('battle')?'battle-reuse':'reuse',e,ci,null);
}

// ═══════════════════════════════════════════════
// PRESET PANEL (PP)
// ═══════════════════════════════════════════════
function openPP(charIdx,mode){
  ppMode=mode;ppCharIdx=charIdx;
  ppVarState={};
  const charList=mode==='battle'?bChars:chars;
  const charObj=charList[charIdx];
  if(!charObj?.presetId)return;
  const pc=PC.find(c=>c.id===charObj.presetId);if(!pc)return;
  const curLog=mode==='battle'?bLog:cLog;
  document.getElementById('pp-title').textContent=pc.name.toUpperCase()+' — ABILITIES';
  // Render crit section
  renderPPCrit(pc,charObj);
  const listEl=document.getElementById('pp-list');listEl.innerHTML='';
  // Resources header
  const ar=activeRes(pc);
  if(ar.length){
    const hdr=document.createElement('div');hdr.className='pp-res-hdr';
    hdr.innerHTML='<div class="pp-res-title">RESOURCES</div><div id="pp-res-body"></div>';
    listEl.appendChild(hdr);
    renderPPRes(pc,charObj.presetId);
  }
  // Abilities
  if(!pc.abilities.length){
    const d=document.createElement('div');d.className='pp-no-ab';d.textContent='No abilities saved.';listEl.appendChild(d);
  } else {
    pc.abilities.forEach(ab=>{
      renderPPAbRow(ab,pc,charObj,charIdx,curLog,ar,listEl);
    });
  }
  document.getElementById('pp').classList.add('on');
}

function renderPPAbRow(ab,pc,charObj,charIdx,curLog,ar,listEl){
  const varIdx=ppVarState[ab.id]??-1; // -1=base
  const hasVars=(ab.variants||[]).length>0;
  // Get active data (base or variant)
  const src=varIdx===-1?ab:ab.variants[varIdx];
  if(!src)return;
  const totalVariants=1+(ab.variants||[]).length;
  const cycleLabel=varIdx===-1?'BASE':(src.tag||'VAR '+(varIdx+1));
  const displayName=src.name||ab.name;
  // Compute dmg/cd for active variant
  const td=abDmg(src,pc.id);
  const dmgType=normDmgType(src.dmgType);
  const linked=ab.cdLinked!==false;
  const cdKey=linked?ab.id:`${ab.id}_${varIdx}`;
  const recent=curLog.find(e=>e.char===charObj.name&&e.cdKey===cdKey);
  const cdRem=recent?getCDRem(recent,curLog):0;
  const cdOk=cdRem<=0;
  let typeTag='';
  if(dmgType==='d')typeTag=`<span style="color:#e67e22"> DELAYED</span>`;
  if(dmgType==='t'){const tk=src.ticki>0?Math.floor(src.tickd/src.ticki):0;typeTag=`<span style="color:#8e44ad"> DOT×${tk}</span>`;}
  const htTag=(src.hitType||'single')==='multi'?`<span style="color:#5dade2"> [MULTI]</span>`:`<span style="color:var(--muted)"> [SINGLE]</span>`;
  let resPreview='';
  if(src.resources&&ar.length){
    const parts=[];
    (src.resources||[]).forEach((r,i)=>{if(!r||!r.mode||!r.amount)return;const rd=pc.resources?.[i];if(!rd?.name)return;parts.push(`<span style="color:${r.mode==='gain'?'var(--green)':'var(--red)'}">${r.mode==='gain'?'+':'-'}${r.amount} ${rd.name}</span>`);});
    if(parts.length)resPreview=`<div style="font-family:var(--mono);font-size:10px;margin-top:3px">${parts.join(' · ')}</div>`;
  }
  const row=document.createElement('div');row.className='pp-row';row.id='pp-ab-row-'+ab.id;
  row.innerHTML=`
    <div style="flex:1;min-width:0">
      <div class="pp-ab-nm">${safe(displayName)}${hasVars?`<span class="var-badge">${safe(cycleLabel)}</span>`:''}${typeTag}${htTag}${src.canCrit?`<span class="crit-tag">CRIT</span>`:''}${src.stunDmg?` <span style="color:#f39c12;font-size:9px;border:1px solid #f39c12;padding:1px 4px">STUN ${src.stunDmg}</span>`:''}</div>
      <div class="pp-ab-meta">DMG <span style="color:var(--text)">${td}</span> · CAST <span style="color:var(--text)">${src.castTime}s</span> · CD <span style="color:var(--text)">${src.cooldown}s</span>${src.effName?` · ⬡ ${safe(src.effName)}`:''}</div>
      ${src.desc?`<div class="pp-ab-meta" style="font-style:italic;white-space:pre-wrap;word-break:break-word">${safe(src.desc)}</div>`:''}
      ${resPreview}
    </div>
    <div class="pp-right">
      ${hasVars?`<button class="cycle-btn" onclick="cyclePPVar(${ab.id},${charIdx})">⟳ CYCLE</button>`:''}
      <div class="cdb ${cdOk?'rdy':'cool'}">${cdOk?'CD READY':'CD '+cdRem.toFixed(2)+'s'}</div>
      <button class="btn btn-ys btn-xs" onclick="usePPAb(${ab.id},${charIdx})">USE</button>
    </div>
  `;
  listEl.appendChild(row);
}

function cyclePPVar(abId,charIdx){
  const charList=ppMode==='battle'?bChars:chars;
  const charObj=charList[charIdx];if(!charObj?.presetId)return;
  const pc=PC.find(c=>c.id===charObj.presetId);if(!pc)return;
  const ab=pc.abilities.find(a=>a.id===abId);if(!ab)return;
  const total=1+(ab.variants||[]).length;
  const cur=ppVarState[abId]??-1;
  ppVarState[abId]=cur+1>=total-1?-1:cur+1; // cycle: -1,0,1,...,n-1 then back to -1
  // Re-render just this row
  const curLog=ppMode==='battle'?bLog:cLog;
  const ar=activeRes(pc);
  const oldRow=document.getElementById('pp-ab-row-'+abId);
  if(oldRow){
    const tmp=document.createElement('div');
    renderPPAbRow(ab,pc,charObj,charIdx,curLog,ar,tmp);
    oldRow.replaceWith(tmp.firstChild);
  }
}
function renderPPCrit(pc,charObj){
  const sec=document.getElementById('pp-crit-section');
  if(!sec)return;
  const hasStats=(pc.critRate!=null&&pc.critRate>0)||(pc.critDmg!=null&&pc.critDmg>0);
  if(!hasStats){sec.style.display='none';return;}
  sec.style.display='block';
  const pid=charObj.presetId;
  const bonus=sCrit[pid]||{bonusCR:0,bonusCD:0};
  const finalCR=(pc.critRate||0)+(bonus.bonusCR||0);
  const finalCD=(pc.critDmg||0)+(bonus.bonusCD||0);
  sec.innerHTML=`
    <div style="font-family:var(--mono);font-size:10px;color:var(--yd);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px">CRIT STATS</div>
    <div class="crit-stat">Base: Crit Rate <span>${pc.critRate||0}%</span> · Crit DMG <span>${pc.critDmg||0}%</span></div>
    <div class="crit-row">
      <div>
        <div class="flbl">Bonus Crit Rate %</div>
        <input type="number" id="pp-bcr" value="${bonus.bonusCR||''}" placeholder="0"
          style="font-family:var(--mono);font-size:12px;padding:5px 7px;background:var(--bg);border:1px solid var(--border);color:var(--text);width:100%"
          oninput="updateCritBonus(${pid})">
      </div>
      <div>
        <div class="flbl">Bonus Crit DMG %</div>
        <input type="number" id="pp-bcd" value="${bonus.bonusCD||''}" placeholder="0"
          style="font-family:var(--mono);font-size:12px;padding:5px 7px;background:var(--bg);border:1px solid var(--border);color:var(--text);width:100%"
          oninput="updateCritBonus(${pid})">
      </div>
    </div>
    <div class="crit-stat" id="pp-crit-final">Final: Crit Rate <span>${finalCR.toFixed(1)}%</span> · Crit DMG <span>${finalCD.toFixed(1)}%</span></div>
  `;
}

function updateCritBonus(pid){
  const bcr=parseFloat(document.getElementById('pp-bcr')?.value)||0;
  const bcd=parseFloat(document.getElementById('pp-bcd')?.value)||0;
  sCrit[pid]={bonusCR:bcr,bonusCD:bcd};
  const pc=PC.find(p=>p.id===pid);
  const finalCR=(pc?.critRate||0)+bcr;
  const finalCD=(pc?.critDmg||0)+bcd;
  const fin=document.getElementById('pp-crit-final');
  if(fin)fin.innerHTML=`Final: Crit Rate <span style="color:var(--y)">${finalCR.toFixed(1)}%</span> · Crit DMG <span style="color:var(--y)">${finalCD.toFixed(1)}%</span>`;
}

function renderPPRes(pc,pid){
  const body=document.getElementById('pp-res-body');if(!body)return;
  const ar=activeRes(pc);body.innerHTML='';
  ar.forEach(r=>{
    const cur=getRes(pid,r.idx);
    const valStr=r.max!=null?`${cur} / ${r.max}`:`${cur}`;
    const item=document.createElement('div');item.className='pp-res-item';
    item.innerHTML=`
      <span class="pp-res-lbl">${r.name}</span>
      <span class="pp-res-cnt" id="pprc-${r.idx}">${valStr}</span>
      <div class="pp-res-btns">
        <button onclick="adjRes(${pid},${r.idx},-1)">−</button>
        <input type="number" id="ppri-${r.idx}" value="1" min="1">
        <button onclick="adjRes(${pid},${r.idx},1)">+</button>
      </div>
    `;
    body.appendChild(item);
  });
}
function adjRes(pid,idx,dir){
  const amt=parseInt(document.getElementById('ppri-'+idx)?.value)||1;
  setRes(pid,idx,getRes(pid,idx)+dir*amt);
  const pc=PC.find(p=>p.id===pid);renderPPRes(pc,pid);
  if(ppMode==='battle')renderBattleStats();else renderCalcStats();
}
function usePPAb(abId,charIdx){
  const charList=ppMode==='battle'?bChars:chars;
  const charObj=charList[charIdx];if(!charObj?.presetId)return;
  const pc=PC.find(c=>c.id===charObj.presetId);if(!pc)return;
  const ab=pc.abilities.find(a=>a.id===abId);if(!ab)return;
  const varIdx=ppVarState[abId]??-1;
  const src=varIdx===-1?ab:(ab.variants||[])[varIdx];
  if(!src)return;
  const curLog=ppMode==='battle'?bLog:cLog;
  // cdKey: linked = abBaseId (shared), unlinked = abBaseId+varIdx (per variant)
  const linked=ab.cdLinked!==false;
  const cdKey=linked?abId:`${abId}_${varIdx}`;
  const recent=curLog.find(e=>e.char===charObj.name&&e.cdKey===cdKey);
  const cdRem=recent?getCDRem(recent,curLog):0;
  const srcWithMeta={...src,abBaseId:abId,cdKey,varTag:varIdx===-1?null:(src.tag||'VAR '+(varIdx+1))};
  const doOpen=()=>openLogModal(ppMode==='battle'?'battle-reuse':'reuse',srcWithMeta,charIdx,srcWithMeta);
  if(cdRem>0)showAlert((src.name||ab.name)+' has '+cdRem.toFixed(2)+'s left on cooldown.',doOpen);
  else doOpen();
}

