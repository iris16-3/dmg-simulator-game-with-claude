        <div><label>DoT Interval (s)</label><input type="number" class="e-ticki" value="${entry.ticki||0}" step="0.1"></div>
        <div><label>DoT Duration (s)</label><input type="number" class="e-tickd" value="${entry.tickd||0}" step="0.1"></div>
        <div><label>Effect Name</label><input type="text" class="e-effn" value="${entry.effName||''}"></div>
        <div><label>Effect Duration (s)</label><input type="number" class="e-effd" value="${entry.effDur||0}" step="0.1"></div>
        <div class="full"><div class="cb-row"><input type="checkbox" class="e-stacks" ${entry.stacks?'checked':''}><label>Effect stacks</label></div></div>
      </div>
      <div class="ea">
        <button class="btn btn-g btn-xs" onclick="saveEdit(${entry.id},${isB})">SAVE</button>
        <button class="btn btn-gh btn-xs" onclick="toggleEdit(${entry.id})">CANCEL</button>
      </div>
    </div>
  `;
  return el;
}
function reuseBtn(id,isB){
  lmMode=isB?'battle-reuse':'reuse';
  const log=isB?bLog:cLog;
  const e=log.find(x=>x.id===id);if(!e)return;
  const charList=isB?bChars:chars;
  const ci=charList.findIndex(c=>c.name===e.char);
  const cdRem=getCDRem(e,log);
  // Pass e as srcAb so resource gain/cost and variant tracking applies on confirm
  const doOpen=()=>openLogModal(lmMode,e,ci,{...e,abBaseId:e.abBaseId,varTag:e.varTag,cdKey:e.cdKey});
  if(cdRem>0)showAlert(e.name+' has '+cdRem.toFixed(2)+'s on cooldown.',doOpen);
  else doOpen();
}
function toggleEdit(id){
  const ef=document.getElementById('ef-'+id);const le=document.getElementById('le-'+id);
  if(!ef||!le)return;ef.classList.toggle('open');le.classList.toggle('editing');
}
function saveEdit(id,isB){
  const log=isB?bLog:cLog;
  const entry=log.find(e=>e.id===id);if(!entry)return;
  const el=document.getElementById('le-'+id);
  const charList=isB?bChars:chars;
  const ci=parseInt(el.querySelector('.e-char').value);
  entry.char=(charList[ci]||charList[0]).name;
  entry.name=el.querySelector('.e-nm').value.trim()||entry.name;
  entry.desc=el.querySelector('.e-desc').value.trim();
  entry.castTime=parseFloat(el.querySelector('.e-cast').value)||0;
  entry.cooldown=parseFloat(el.querySelector('.e-cd').value)||0;
  entry.dmgType=el.querySelector('.e-dmt').value;
  entry.hitType=el.querySelector('.e-hit').value;
  const fr=el.querySelector('.e-flat').value;
  entry.dmgFlat=fr!==''?parseFloat(fr):null;
  entry.stat=parseFloat(el.querySelector('.e-stat').value)||0;
  entry.mult=parseFloat(el.querySelector('.e-mult').value)||0;
  entry.b1=parseFloat(el.querySelector('.e-b1').value)||0;
  entry.b2=parseFloat(el.querySelector('.e-b2').value)||0;
  entry.delay=parseFloat(el.querySelector('.e-delay').value)||0;
  entry.ticki=parseFloat(el.querySelector('.e-ticki').value)||0;
  entry.tickd=parseFloat(el.querySelector('.e-tickd').value)||0;
  entry.effName=el.querySelector('.e-effn').value.trim();
  entry.effDur=parseFloat(el.querySelector('.e-effd').value)||0;
  entry.stacks=el.querySelector('.e-stacks').checked;
  if(isB){recalcLog(bLog);recomputeHP();renderBattle();}
  else{recalcLog(cLog);renderApp();}
}
function deleteEntry(id,isB){
  if(isB){const i=bLog.findIndex(e=>e.id===id);if(i>=0){bLog.splice(i,1);recalcLog(bLog);recomputeHP();renderBattle();}}
  else{const i=cLog.findIndex(e=>e.id===id);if(i>=0){cLog.splice(i,1);recalcLog(cLog);renderApp();}}
}
function recomputeHP(){
  // Reset HP and stun state
  bEnemies.forEach(e=>{e.hp=e.maxHp;e.stunCur=e.stunMax??null;e.stunStart=null;});
  // Replay log oldest-first
  for(let i=bLog.length-1;i>=0;i--){
    const entry=bLog[i];const rawDmg=entryDmg(entry);
    (entry.targets||[]).forEach(tn=>{
      const en=bEnemies.find(e=>e.name===tn);if(!en)return;
      const eff=applyResistance(rawDmg,en);
      en.hp=Math.max(0,en.hp-eff);
      applyStunDmg(en,entry.stunDmg||0);
    });
    entry.totalBattleDmg=rawDmg*(entry.targets?.length||1);
    checkStunExpiry();
  }
  if(bEnemies.some(e=>e.hp>0))bOver=false;
}

