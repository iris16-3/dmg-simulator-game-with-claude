// LOG MODAL
// ═══════════════════════════════════════════════
function openLogModal(mode,src,charIdx,srcAb){
  lmMode=mode;pendingAb=srcAb||null;
  const isBattle=mode.startsWith('battle');
  const charList=isBattle?bChars:chars;
  fillCharSel(charList);
  clearLM();setTab('lm','n');
  document.getElementById('lm-title').textContent=mode.includes('reuse')?'REUSE ABILITY':'LOG ABILITY';
  document.getElementById('lm-ok').textContent='LOG';
  if(src){
    if(charIdx>=0)document.getElementById('lm-char').value=charIdx;
    document.getElementById('lm-name').value=src.name||'';
    document.getElementById('lm-desc').value=src.desc||'';
    document.getElementById('lm-cast').value=src.castTime||'';
    document.getElementById('lm-cd').value=src.cooldown||'';
    document.getElementById('lm-hit').value=src.hitType||'single';
    setTab('lm',normDmgType(src.dmgType));
    const s=normDmgType(src.dmgType);
    if(src.dmgFlat!=null)document.getElementById('lm-flat-'+s).value=src.dmgFlat;
    if((src.mult||0)>0||(src.stat||0)>0||(src.b1||0)>0||(src.b2||0)>0){
      ['stat','mult','b1','b2'].forEach(k=>{const el=document.getElementById('lm-'+k+'-'+s);if(el)el.value=src[k]||0;});
      const adv=document.getElementById('lm-adv-'+s);const btn=document.getElementById('lm-advbtn-'+s);
      if(adv){adv.classList.add('on');if(btn)btn.textContent=btn.textContent.replace('▶','▼');}
      updAdv('lm',s);
    }
    if(s==='d')document.getElementById('lm-delay').value=src.delay||0;
    if(s==='t'){document.getElementById('lm-ticki').value=src.ticki||0;document.getElementById('lm-tickd').value=src.tickd||0;updDotPrev('lm');}
    document.getElementById('lm-effn').value=src.effName||'';
    document.getElementById('lm-effd').value=src.effDur||'';
    document.getElementById('lm-stacks').checked=src.stacks||false;
    const lmcc=document.getElementById('lm-cancrit');if(lmcc)lmcc.checked=src.canCrit||false;
    const stundmgEl=document.getElementById('lm-stundmg');
    if(stundmgEl)stundmgEl.value=src.stunDmg||'';
  }
  openOv('ov-log');
}
function clearLM(){
  ['lm-name','lm-desc','lm-effn','lm-stundmg'].forEach(id=>document.getElementById(id).value='');
  ['lm-flat-n','lm-flat-d','lm-flat-t','lm-cast','lm-cd','lm-delay','lm-ticki','lm-tickd','lm-effd',
   'lm-stat-n','lm-mult-n','lm-b1-n','lm-b2-n','lm-stat-d','lm-mult-d','lm-b1-d','lm-b2-d',
   'lm-stat-t','lm-mult-t','lm-b1-t','lm-b2-t'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  ['lm-prev-n','lm-prev-d','lm-prev-t','lm-dot-prev'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent='';});
  ['n','d','t'].forEach(s=>{
    const adv=document.getElementById('lm-adv-'+s);const btn=document.getElementById('lm-advbtn-'+s);
    if(adv)adv.classList.remove('on');if(btn&&btn.textContent.includes('▼'))btn.textContent=btn.textContent.replace('▼','▶');
  });
  document.getElementById('lm-stacks').checked=false;
}
function confirmLog(){
  const ci=parseInt(document.getElementById('lm-char').value)||0;
  const name=document.getElementById('lm-name').value.trim();if(!name){alert('Name required.');return;}
  const isBattle=lmMode.startsWith('battle');
  const charList=isBattle?bChars:chars;
  const charObj=charList[ci]||charList[0];
  const s=normDmgType(lmTab);
  const flatRaw=document.getElementById('lm-flat-'+s)?.value??'';
  const cbs=charObj.presetId?getBaseStat(charObj.presetId):0;
  const entry={
    id:isBattle?bLogId++:cLogId++,
    char:charObj.name,name,
    desc:document.getElementById('lm-desc').value.trim(),
    castTime:parseFloat(document.getElementById('lm-cast').value)||0,
    cooldown:parseFloat(document.getElementById('lm-cd').value)||0,
    hitType:document.getElementById('lm-hit').value,
    dmgType:s,
    dmgFlat:flatRaw!==''?parseFloat(flatRaw):null,
    stat:parseFloat(document.getElementById('lm-stat-'+s)?.value)||0,
    mult:parseFloat(document.getElementById('lm-mult-'+s)?.value)||0,
    b1:parseFloat(document.getElementById('lm-b1-'+s)?.value)||0,
    b2:parseFloat(document.getElementById('lm-b2-'+s)?.value)||0,
    delay:parseFloat(document.getElementById('lm-delay')?.value)||0,
    ticki:parseFloat(document.getElementById('lm-ticki')?.value)||0,
    tickd:parseFloat(document.getElementById('lm-tickd')?.value)||0,
    effName:document.getElementById('lm-effn').value.trim(),
    effDur:parseFloat(document.getElementById('lm-effd').value)||0,
    stacks:document.getElementById('lm-stacks').checked,
    cbs,timeAt:0,targets:null,totalBattleDmg:0,
    resources:pendingAb?.resources||null,
    abBaseId:pendingAb?.abBaseId||null,
    varTag:pendingAb?.varTag||null,
    cdKey:pendingAb?.cdKey||null,
    stunDmg:parseFloat(document.getElementById('lm-stundmg')?.value)||0,
    canCrit:pendingAb?.canCrit||false,
    isCrit:false,  // set below
    critMult:1     // set below
  };
  // Crit roll
  if(entry.canCrit){
    const didCrit=rollCrit(true,charObj);
    if(didCrit){
      entry.isCrit=true;
      const{dmg:critDmgPct}=getCharCritStats(charObj);
      entry.critMult=1+(critDmgPct/100);
      // Apply crit multiplier to flat dmg if set, otherwise store multiplier for entryDmg
      if(entry.dmgFlat!=null)entry.dmgFlat=Math.round(entry.dmgFlat*entry.critMult);
      else entry.critApplied=true; // flag for entryDmg to apply
    }
  }
  // Resource check
  const short=checkRes(pendingAb,charObj);
  if(short.length){
    const lines=short.map(r=>`${r.name}: need ${r.need}, have ${r.have}`).join('\n');
    showRW('Not enough resources:\n'+lines,()=>dispatch(entry,isBattle,charObj,true));
    return;
  }
  dispatch(entry,isBattle,charObj,false);
}
function dispatch(entry,isBattle,charObj,forceRes){
  applyRes(pendingAb,charObj,forceRes);
  closeOv('ov-log');closePP();
  if(isBattle&&entry.hitType==='single'){
    pendingEntry=entry;openTargetPicker();
  } else if(isBattle&&entry.hitType==='multi'){
    const living=bEnemies.filter(e=>e.hp>0);
    const rawDmg=entryDmg(entry);
    entry.targets=living.map(e=>e.name);
    let totalDealt=0;
    living.forEach(e=>{
      const eff=applyResistance(rawDmg,e);
      e.hp=Math.max(0,e.hp-eff);
      totalDealt+=eff;
      applyStunDmg(e,entry.stunDmg||0);
    });
    entry.totalBattleDmg=totalDealt;
    bLog.unshift(entry);recalcLog(bLog);checkStunExpiry();renderBattle();checkWin();
  } else {
    cLog.unshift(entry);recalcLog(cLog);renderApp();
  }
  pendingAb=null;
}

// ═══════════════════════════════════════════════
// TARGET PICKER
// ═══════════════════════════════════════════════
function openTargetPicker(){
  const list=document.getElementById('tgt-list');list.innerHTML='';
  bEnemies.forEach((e,i)=>{
    if(e.hp<=0)return;
    const btn=document.createElement('button');btn.className='tgt-btn';
    const res=e.res??0;const stunned=isEnemyStunned(e);
    btn.innerHTML=`<div class="tgt-nm">${e.name}${stunned?` <span style="color:#f39c12">[STUNNED]</span>`:''}</div><div class="tgt-hp">${e.hp} / ${e.maxHp} HP${res!==0?` · RES ${res>0?'+':''}${res}%`:''}</div>`;
    btn.onclick=()=>applyTarget(i);
    list.appendChild(btn);
  });
  openOv('ov-target');
}
function applyTarget(i){
  if(!pendingEntry)return;
  const e=bEnemies[i];
  const rawDmg=entryDmg(pendingEntry);
  const eff=applyResistance(rawDmg,e);
  pendingEntry.targets=[e.name];
  pendingEntry.totalBattleDmg=eff;
  e.hp=Math.max(0,e.hp-eff);
  applyStunDmg(e,pendingEntry.stunDmg||0);
  bLog.unshift(pendingEntry);recalcLog(bLog);checkStunExpiry();
  closeOv('ov-target');pendingEntry=null;
  renderBattle();checkWin();
}

