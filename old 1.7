  const advLine=isAdv?` <span style="color:var(--muted);font-size:10px">[${entry.cbs||0}+${entry.stat}=${entry.stat+(entry.cbs||0)} ×${entry.mult}%${entry.b1?' +B'+entry.b1+'%':''}${entry.b2?' +B'+entry.b2+'%':''}]</span>`:'';
  let dmtLabel='';
  if(entry.dmgType==='d')dmtLabel=`<div class="le-dmt dmt-d">⏱ DELAYED +${entry.delay}s → ${baseDmg} dmg${advLine}</div>`;
  if(entry.dmgType==='t'){const tk=entry.ticki>0?Math.floor(entry.tickd/entry.ticki):0;dmtLabel=`<div class="le-dmt dmt-dot">◈ DOT ${baseDmg}/tick ×${tk}${isB?' per target':''}${advLine}</div>`;}
  const tgtStr=isB&&entry.targets?.length?(entry.hitType==='multi'?'ALL: '+entry.targets.join(', '):'→ '+entry.targets[0]):'';
  const htTag=`<span style="font-size:10px;color:${entry.hitType==='multi'?'#5dade2':'var(--muted)'}">[${entry.hitType==='multi'?'MULTI':'SINGLE'}]</span>`;
  const charOpts=(charList||[]).map((c,i)=>`<option value="${i}" ${c.name===entry.char?'selected':''}>${c.name}</option>`).join('');
  const dmtOpts=['n','d','t'].map(t=>`<option value="${t}" ${entry.dmgType===t?'selected':''}>${t==='n'?'NORMAL':t==='d'?'DELAYED':'DOT'}</option>`).join('');
  const hitOpts=`<option value="single" ${entry.hitType!=='multi'?'selected':''}>Single</option><option value="multi" ${entry.hitType==='multi'?'selected':''}>Multi</option>`;
