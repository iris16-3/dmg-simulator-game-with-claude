function checkWin(){
  if(bOver||!bEnemies.every(e=>e.hp<=0))return;
  bOver=true;
  const tt=logTotalTime(bLog);
  const totalDmg=bLog.reduce((s,e)=>s+(e.totalBattleDmg||0),0);
