function renderEnemyGrid(){
  const grid=document.getElementById('enemy-grid');grid.innerHTML='';
  bEnemies.forEach((e,i)=>{
    const pct=e.maxHp>0?(e.hp/e.maxHp)*100:0;
    const dead=e.hp<=0;
    const stunned=!dead&&isEnemyStunned(e);
    const stunRem=stunned?stunRemaining(e):0;
    const activeRes=getEnemyRes(e);
    const hasStun=e.stunMax!=null;
    const stunPct=hasStun&&e.stunMax>0?((e.stunCur??e.stunMax)/e.stunMax)*100:100;
    const card=document.createElement('div');
    card.className='ec'+(dead?' dead':'')+(stunned?' stunned':'');
    card.innerHTML=`
      <div class="en">${e.name}</div>
      <div class="ehp">${dead?'DEAD':e.hp+' / '+e.maxHp}</div>
      <div class="hpw"><div class="hpb${pct>50?'':pct>25?' mid':' low'}" style="width:${pct}%"></div></div>
      ${dead?'<div class="dead-lbl">DEFEATED</div>':''}
      ${stunned?`<div class="stun-tag">⚡ STUNNED ${stunRem.toFixed(1)}s</div>`:''}
      ${hasStun&&!dead&&!stunned?`<div class="stun-bar-wrap"><div class="stun-bar" style="width:${stunPct}%"></div></div><div style="font-family:var(--mono);font-size:9px;color:#f39c12;margin-top:1px">${(e.stunCur??e.stunMax).toFixed(0)}/${e.stunMax} STUN</div>`:''}
      ${!dead&&activeRes!==0?`<div class="res-tag">RES ${activeRes>0?'+':''}${activeRes}%${stunned?' (stunned)':''}</div>`:''}
    `;
    if(!dead)card.onclick=()=>openEnemyEditor(i);
    grid.appendChild(card);
  });
