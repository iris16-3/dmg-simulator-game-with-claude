<script>
// ═══════════════════════════════════════════════
// STORAGE
// ═══════════════════════════════════════════════
// Safe text for innerHTML — escapes HTML chars, preserves newlines
function safe(str){
  if(!str)return '';
  return str
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;');
  // CSS white-space:pre-wrap handles \n visually, no <br> needed
}

// Normalize old dmgType strings to new single-char format
function normDmgType(t){
  if(!t)return 'n';
  if(t==='normal'||t==='n')return 'n';
  if(t==='delayed'||t==='d')return 'd';
  if(t==='dot'||t==='t')return 't';
  return 'n';
}

const SAVE_KEY='dmgcalc_v4';
function savePresets(){
  try{localStorage.setItem(SAVE_KEY,JSON.stringify({chars:PC,nextPCId,nextAbId}));}catch(e){}
}
function loadPresets(){
  try{
    const r=localStorage.getItem(SAVE_KEY);
    if(r)return JSON.parse(r);
    // Migrate from older versions
    for(const k of['dmgcalc_v3','dmgcalc_v2']){
      const old=localStorage.getItem(k);
      if(old){
        const d=JSON.parse(old);
        if(d.chars)d.chars=d.chars.map(c=>({baseStat:0,desc:'',resources:[{name:'',max:null},{name:'',max:null},{name:'',max:null}],...c,
          abilities:(c.abilities||[]).map(ab=>({
            id:ab.id!=null?ab.id:nextAbId++,
            dmgFlat:ab.dmgFlat!=null?ab.dmgFlat:(ab.dmg!=null?ab.dmg:null),
            stat:0,mult:0,b1:0,b2:0,hitType:'single',resources:null,variants:[],...ab,
            dmgType:normDmgType(ab.dmgType),
            ticki:ab.ticki||ab.dotInterval||0,
            tickd:ab.tickd||ab.dotDuration||0,
            effName:ab.effName||ab.effectName||'',
            effDur:ab.effDur||ab.effectDuration||0,
          }))
        }));
        return d;
      }
    }
  }catch(e){}
  return null;
}

// ═══════════════════════════════════════════════
// GLOBAL STATE
// ═══════════════════════════════════════════════
const _s=loadPresets();
let PC=_s?_s.chars:[];           // preset characters
let nextPCId=_s?_s.nextPCId:1;
let nextAbId=_s?_s.nextAbId:1;

// Calc state
let chars=[];   // [{name,presetId}]
let cLog=[];
let cLogId=1;

// Battle state
let bChars=[];
let bEnemies=[];
let bLog=[];
let bLogId=1;
let bTimerTotal=0;
let bOver=false;

// Resources: presetId -> [cur0,cur1,cur2]
let sRes={};
// Crit bonuses: presetId -> {bonusCR, bonusCD}
let sCrit={};

// Modal/ui state
let lmMode='add';       // add|reuse|battle-add|battle-reuse
let lmTab='n';          // n|d|t
let aeTab='n';
let aePCId=null;
let aeAbId=null;
let aeVarIdx=null;  // null = base ability, number = variant index being edited
let epcId=null;
let ppMode='calc';      // calc|battle
let ppCharIdx=null;
let ppVarState={};    // abId -> current variant index (-1 = base)
let pendingEntry=null;  // waiting for target picker
let pendingAb=null;     // source ability for resource application
let pcExpanded=new Set();

// ═══════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════
function openOv(id){document.getElementById(id).classList.add('on');}
function closeOv(id){document.getElementById(id).classList.remove('on');}
function closePP(){document.getElementById('pp').classList.remove('on');}

function showAlert(msg,cb){
  document.getElementById('alert-msg').textContent=msg;
  document.getElementById('alert-ok').onclick=()=>{closeOv('ov-alert');cb();};
  openOv('ov-alert');
}
function showCF(title,msg,cb){
  document.getElementById('cf-title').textContent=title;
  document.getElementById('cf-msg').textContent=msg;
  document.getElementById('cf-ok').onclick=()=>{closeOv('ov-cf');cb();};
  openOv('ov-cf');
}
function showRW(msg,cb){
  document.getElementById('rw-msg').textContent=msg;
  document.getElementById('rw-ok').onclick=()=>{closeOv('ov-rw');cb();};
  openOv('ov-rw');
}

function resolveChars(sel){
  const out=[];
  document.querySelectorAll(sel+' input[type=text]').forEach((inp,i)=>{
    const v=inp.value.trim();
    if(!v){out.push({name:'Char '+(i+1),presetId:null});return;}
    const m=v.match(/^#(\d+)$/i);
    if(m){const pid=parseInt(m[1]);const pc=PC.find(c=>c.id===pid);if(pc){out.push({name:pc.name,presetId:pid});return;}}
    out.push({name:v,presetId:null});
  });
  return out;
}
function initRes(charList){charList.forEach(c=>{if(c.presetId&&!sRes[c.presetId])sRes[c.presetId]=[0,0,0];});}
function getRes(pid,i){return(sRes[pid]||[0,0,0])[i]||0;}
function setRes(pid,i,v){
  if(!sRes[pid])sRes[pid]=[0,0,0];
  const pc=PC.find(p=>p.id===pid);
  const max=pc?.resources?.[i]?.max;
  v=Math.max(0,v);
  if(max!=null)v=Math.min(max,v);
  sRes[pid][i]=v;
}
function activeRes(pc){
  if(!pc?.resources)return[];
  return pc.resources.map((r,i)=>({...r,idx:i})).filter(r=>r&&r.name);
}
function getBaseStat(pid){const pc=PC.find(p=>p.id===pid);return pc?pc.baseStat||0:0;}
function computeDmg(flat,stat,mult,b1,b2,cbs,legacyDmg){
  if(flat!==null&&flat!==undefined&&flat!=='')return parseFloat(flat)||0;
  const m=parseFloat(mult)||0;const s=(parseFloat(stat)||0)+(parseFloat(cbs)||0);
  if(m>0&&s>0)return Math.round(s*(m/100)*(1+(parseFloat(b1)||0)/100)*(1+(parseFloat(b2)||0)/100));
  if(legacyDmg!=null&&legacyDmg!=='')return parseFloat(legacyDmg)||0;
  return 0;
}
function entryDmg(e){
  const base=computeDmg(e.dmgFlat,e.stat,e.mult,e.b1,e.b2,e.cbs||0,e.dmg);
  const t=normDmgType(e.dmgType);
  let dmg=t==='t'?(!e.ticki||e.ticki<=0?0:Math.floor(e.tickd/e.ticki)*base):base;
  if(e.critApplied&&e.critMult)dmg=Math.round(dmg*e.critMult);
  return dmg;
}
function abDmg(ab,pid){
  const cbs=pid!=null?getBaseStat(pid):0;
  const base=computeDmg(ab.dmgFlat,ab.stat,ab.mult,ab.b1,ab.b2,cbs,ab.dmg);
  const t=normDmgType(ab.dmgType);
  if(t==='t'){if(!ab.ticki||ab.ticki<=0)return 0;return Math.floor(ab.tickd/ab.ticki)*base;}
  return base;
}
function recalcLog(log){
  let c=0;for(let i=log.length-1;i>=0;i--){c+=log[i].castTime;log[i].timeAt=parseFloat(c.toFixed(4));}
}
function logTotalTime(log){return log.length>0?log[0].timeAt:0;}
function getCDRem(entry,log){
  const tt=logTotalTime(log);
  const castTime=parseFloat(entry.castTime)||0;
  const cooldown=parseFloat(entry.cooldown)||0;
  const timeAt=parseFloat(entry.timeAt)||0;
  const castStart=timeAt-castTime;
  return Math.max(0,parseFloat((castStart+cooldown-tt).toFixed(4)));
}
function checkRes(ab,charObj){
  if(!charObj.presetId||!ab?.resources)return[];
  const pc=PC.find(p=>p.id===charObj.presetId);if(!pc)return[];
  const short=[];
  (ab.resources||[]).forEach((r,i)=>{
    if(!r||r.mode!=='cost'||!r.amount)return;
    const rDef=pc.resources?.[i];if(!rDef?.name)return;
    const have=getRes(charObj.presetId,i);
    if(have<r.amount)short.push({idx:i,name:rDef.name,need:r.amount,have});
  });
  return short;
}
function applyRes(ab,charObj,force){
  if(!charObj?.presetId||!ab?.resources)return;
  const pc=PC.find(p=>p.id===charObj.presetId);if(!pc)return;
  (ab.resources||[]).forEach((r,i)=>{
    if(!r||!r.mode||!r.amount)return;
    const rDef=pc.resources?.[i];if(!rDef?.name)return;
    const cur=getRes(charObj.presetId,i);
    if(r.mode==='gain')setRes(charObj.presetId,i,cur+r.amount);
    else if(r.mode==='cost')setRes(charObj.presetId,i,cur-(force?cur:r.amount));
  });
}
// ── CRIT HELPERS ──
function getCharCritStats(charObj){
  if(!charObj?.presetId)return{rate:0,dmg:0};
  const pc=PC.find(p=>p.id===charObj.presetId);
  const base={rate:pc?.critRate||0,dmg:pc?.critDmg||0};
  const bonus=sCrit[charObj.presetId]||{bonusCR:0,bonusCD:0};
  return{rate:base.rate+(bonus.bonusCR||0),dmg:base.dmg+(bonus.bonusCD||0)};
}

function rollCrit(canCrit,charObj){
  if(!canCrit)return false;
  const{rate}=getCharCritStats(charObj);
  if(!rate||rate<=0)return false;
  return Math.random()*100<rate;
}

function applyCritDmg(baseDmg,charObj){
  const{dmg}=getCharCritStats(charObj);
  return Math.round(baseDmg*(1+dmg/100));
}

function getActiveEffects(log){
  const tt=logTotalTime(log);const map={};
  for(let i=log.length-1;i>=0;i--){
    const e=log[i];if(!e.effName||!e.effDur)continue;
    const end=(e.timeAt-e.castTime)+e.effDur;
    if(!map[e.effName])map[e.effName]={stacks:e.stacks,ends:[]};
    if(e.stacks)map[e.effName].ends.push(end);else map[e.effName].ends=[end];
  }
  const out=[];
  for(const[name,d]of Object.entries(map)){
    const live=d.ends.filter(t=>t>tt);
    if(live.length)out.push({name,stacks:live.length,rem:Math.max(...live)-tt});
  }
  return out;
}

// ═══════════════════════════════════════════════
// SETUP — INPUTS
// ═══════════════════════════════════════════════
function setCC(){buildInputs('cc-inputs',parseInt(document.getElementById('cc').value)||1,'Name or #ID');}
function setBC(){buildInputs('bc-inputs',parseInt(document.getElementById('bc').value)||1,'Name or #ID');}
function setEC(){
  const n=Math.max(1,parseInt(document.getElementById('ec').value)||1);
  const c=document.getElementById('ec-inputs');
  const ex=[...c.querySelectorAll('.srow')].map(r=>({n:r.querySelector('input[type=text]')?.value||'',h:r.querySelector('input[type=number]')?.value||'100'}));
  c.innerHTML='';
  for(let i=0;i<n;i++){
    const d=document.createElement('div');d.className='srow';
    d.innerHTML=`<input type="text" placeholder="Enemy ${i+1}" style="flex:1" value="${ex[i]?.n||''}"><input type="number" placeholder="HP" style="width:80px;flex-shrink:0" value="${ex[i]?.h||'100'}">`;
    c.appendChild(d);
  }
}
function buildInputs(cId,n,ph){
  const c=document.getElementById(cId);
  const ex=[...c.querySelectorAll('input')].map(i=>i.value);
  c.innerHTML='';
  for(let i=0;i<n;i++){const inp=document.createElement('input');inp.type='text';inp.placeholder=ph;inp.value=ex[i]||'';c.appendChild(inp);}
}

// ═══════════════════════════════════════════════
// START SESSIONS
// ═══════════════════════════════════════════════
function startCalc(){
  chars=resolveChars('#cc-inputs');
  cLog=[];cLogId=1;sRes={};initRes(chars);
  document.getElementById('setup').style.display='none';
  document.getElementById('app').style.display='flex';
  fillCharSel(chars);renderApp();updateUAToggle();
}
function startBattle(){
  bChars=resolveChars('#bc-inputs');
  if(!bChars.length){alert('Add at least one character.');return;}
  bEnemies=[];
  document.querySelectorAll('#ec-inputs .srow').forEach((row,i)=>{
    const nm=row.querySelector('input[type=text]')?.value.trim()||'Enemy '+(i+1);
    const hp=parseInt(row.querySelector('input[type=number]')?.value)||100;
    bEnemies.push({name:nm,maxHp:hp,hp});
  });
  if(!bEnemies.length){alert('Add at least one enemy.');return;}
  bTimerTotal=parseFloat(document.getElementById('bc-timer').value)||0;
  bLog=[];bLogId=1;bOver=false;sRes={};initRes(bChars);
  document.getElementById('setup').style.display='none';
  document.getElementById('battle').style.display='flex';
  fillCharSel(bChars);renderBattle();updateUAToggle();
}
function fillCharSel(charList){
  const sel=document.getElementById('lm-char');sel.innerHTML='';
  charList.forEach((c,i)=>{const o=document.createElement('option');o.value=i;o.textContent=c.presetId?c.name+' [#'+c.presetId+']':c.name;sel.appendChild(o);});
}

// ═══════════════════════════════════════════════
// PRESET LIBRARY
// ═══════════════════════════════════════════════
function addPC(){
  const rawId=document.getElementById('np-id').value.trim().replace(/^#/,'');
  const name=document.getElementById('np-name').value.trim();
  if(!rawId){alert('Enter an ID.');return;}if(!name){alert('Enter a name.');return;}
  const pid=parseInt(rawId);
  if(isNaN(pid)||pid<=0){alert('ID must be a positive number.');return;}
  if(PC.find(c=>c.id===pid)){alert('ID #'+pid+' already taken.');return;}
  const baseStat=parseFloat(document.getElementById('np-stat').value)||0;
  const desc=document.getElementById('np-desc').value.trim();
  PC.push({id:pid,name,baseStat,desc,resources:[{name:'',max:null},{name:'',max:null},{name:'',max:null}],abilities:[]});
  savePresets();
  document.getElementById('np-id').value='';document.getElementById('np-name').value='';
  document.getElementById('np-stat').value='';document.getElementById('np-desc').value='';
  renderLibrary();
}
function delPC(pid){showCF('DELETE','Delete this preset character and all their abilities?',()=>{PC=PC.filter(c=>c.id!==pid);savePresets();renderLibrary();});}
function renamePC(pid){
  const card=document.getElementById('pc-'+pid);
  card.querySelector('.pc-nm').style.display='none';
  const ei=card.querySelector('.pc-nm-edit');ei.classList.add('on');ei.focus();ei.select();
}
function saveRename(pid){
  const card=document.getElementById('pc-'+pid);
  const v=card.querySelector('.pc-nm-edit').value.trim();
  if(v){const pc=PC.find(c=>c.id===pid);if(pc)pc.name=v;savePresets();}
  renderLibrary();
}
function openEPC(pid){
  epcId=pid;const pc=PC.find(c=>c.id===pid);if(!pc)return;
  document.getElementById('epc-title').textContent='EDIT — '+pc.name;
  document.getElementById('epc-stat').value=pc.baseStat||'';
  document.getElementById('epc-desc').value=pc.desc||'';
  document.getElementById('epc-cr').value=pc.critRate??'';
  document.getElementById('epc-cd').value=pc.critDmg??'';
  for(let i=0;i<3;i++){
    const r=pc.resources?.[i]||{};
    document.getElementById('epc-r'+i+'n').value=r.name||'';
    document.getElementById('epc-r'+i+'m').value=r.max!=null?r.max:'';
  }
  openOv('ov-epc');
}
function saveEPC(){
  const pc=PC.find(c=>c.id===epcId);if(!pc)return;
  pc.baseStat=parseFloat(document.getElementById('epc-stat').value)||0;
  pc.desc=document.getElementById('epc-desc').value.trim();
  const crRaw=document.getElementById('epc-cr').value;
  const cdRaw=document.getElementById('epc-cd').value;
  pc.critRate=crRaw!==''?parseFloat(crRaw):null;
  pc.critDmg=cdRaw!==''?parseFloat(cdRaw):null;
  pc.resources=[];
  for(let i=0;i<3;i++){
    const nm=document.getElementById('epc-r'+i+'n').value.trim();
    const mx=document.getElementById('epc-r'+i+'m').value;
    pc.resources.push({name:nm,max:mx!==''?parseInt(mx):null});
  }
  savePresets();closeOv('ov-epc');renderLibrary();
}
function toggleExpand(pid){pcExpanded.has(pid)?pcExpanded.delete(pid):pcExpanded.add(pid);renderLibrary();}

function renderLibrary(){
  const el=document.getElementById('pc-list');
  if(!PC.length){el.innerHTML='<div style="font-family:var(--mono);font-size:11px;color:var(--muted);text-align:center;padding:10px">// no preset characters yet</div>';return;}
  el.innerHTML='';
  [...PC].reverse().forEach(pc=>{
    const exp=pcExpanded.has(pc.id);
    const card=document.createElement('div');card.className='pc-card';card.id='pc-'+pc.id;
    // Ensure all abilities have ids (guard against old data)
    pc.abilities.forEach(ab=>{if(ab.id==null){ab.id=nextAbId++;savePresets();}if(!ab.variants)ab.variants=[];});
    const abHtml=pc.abilities.length?pc.abilities.map(ab=>{
      const td=abDmg(ab,pc.id);
      const typeTag=normDmgType(ab.dmgType)!=='n'?` <span style="color:${normDmgType(ab.dmgType)==='t'?'#8e44ad':'#e67e22'}">[${normDmgType(ab.dmgType)==='t'?'DOT':'DELAYED'}]</span>`:'';
      const varHtml=(ab.variants||[]).map((vr,vi)=>{
        const vtd=abDmg(vr,pc.id);
        return `<div class="var-row">
          <div class="var-tag">▸ ${safe(vr.tag||'VARIANT')}</div>
          <div class="var-nm">${safe(vr.name||ab.name)}${vr.canCrit?` <span style="color:#e74c3c;font-size:9px;border:1px solid #e74c3c;padding:1px 4px">CRIT</span>`:''}${vr.stunDmg?` <span style="color:#f39c12;font-size:9px;border:1px solid #f39c12;padding:1px 4px">STUN ${vr.stunDmg}</span>`:''}</div>
          <div class="var-meta">DMG ${vtd} · CAST ${vr.castTime}s · CD ${vr.cooldown}s${vr.effName?' · ⬡ '+safe(vr.effName):''}</div>
          ${vr.desc?`<div class="var-meta" style="font-style:italic;white-space:pre-wrap;word-break:break-word">${safe(vr.desc)}</div>`:''}
          <div class="var-acts">
            <button class="btn btn-gh btn-xs" onclick="openAEEditVariant(${pc.id},${ab.id},${vi})">EDIT</button>
            <button class="btn btn-r btn-xs" onclick="delVariant(${pc.id},${ab.id},${vi})">DEL</button>
          </div>
        </div>`;
      }).join('');
      return `<div class="ab-row">
        <div class="ab-info">
          <div class="ab-nm">${safe(ab.name)}${typeTag}${ab.canCrit?` <span style="color:#e74c3c;font-size:9px;border:1px solid #e74c3c;padding:1px 4px">CRIT</span>`:''}${ab.stunDmg?` <span style="color:#f39c12;font-size:9px;border:1px solid #f39c12;padding:1px 4px">STUN ${ab.stunDmg}</span>`:''}</div>
          <div class="ab-meta">DMG ${td} · CAST ${ab.castTime}s · CD ${ab.cooldown}s${ab.effName?' · ⬡ '+safe(ab.effName):''}</div>
          ${ab.desc?`<div class="ab-meta" style="font-style:italic;white-space:pre-wrap;word-break:break-word">${safe(ab.desc)}</div>`:''}
        </div>
        <div class="ab-acts">
          <button class="btn btn-gh btn-xs" onclick="toggleCDLink(${pc.id},${ab.id})" title="${ab.cdLinked===false?'Cooldowns: Unlinked':'Cooldowns: Linked'}"
            style="color:${ab.cdLinked===false?'#e67e22':'var(--yd)'}">
            ${ab.cdLinked===false?'CD: UNLINKED':'CD: LINKED'}
          </button>
          <button class="btn btn-gh btn-xs" onclick="openAEVariant(${pc.id},${ab.id})">+ VAR</button>
          <button class="btn btn-gh btn-xs" onclick="openAE(${pc.id},${ab.id})">EDIT</button>
          <button class="btn btn-r btn-xs" onclick="delAb(${pc.id},${ab.id})">DEL</button>
        </div>
        ${varHtml?`<div class="var-list">${varHtml}</div>`:''}
      </div>`;
    }).join(''):'<div class="pc-no-ab">no abilities saved yet</div>';
    const resList=activeRes(pc);
    const resStr=resList.length?` · <span style="color:var(--yd)">${resList.map(r=>r.name).join(', ')}</span>`:'';
    card.innerHTML=`
      <div class="pc-head">
        <div class="pc-meta">
          <div class="pc-id">#${pc.id}${pc.baseStat?' · STAT '+pc.baseStat:''}${pc.critRate!=null?` · CR ${pc.critRate}%`:''}${pc.critDmg!=null?` · CD ${pc.critDmg}%`:''}${resStr}</div>
          <div class="pc-nm">${pc.name}</div>
          <input class="pc-nm-edit" type="text" value="${pc.name}" onblur="saveRename(${pc.id})" onkeydown="if(event.key==='Enter')saveRename(${pc.id})">
          ${pc.desc?`<div class="pc-desc">${pc.desc}</div>`:''}
        </div>
        <div class="pc-acts">
          <button class="btn btn-gh btn-xs" onclick="toggleExpand(${pc.id})">${exp?'▲':'▼'}</button>
          <button class="btn btn-gh btn-xs" onclick="renamePC(${pc.id})">RENAME</button>
          <button class="btn btn-gh btn-xs" onclick="openEPC(${pc.id})">EDIT</button>
          <button class="btn btn-ys btn-xs" onclick="openAE(${pc.id},null)">+ ABILITY</button>
          <button class="btn btn-r btn-xs" onclick="delPC(${pc.id})">DELETE</button>
        </div>
      </div>
      ${exp?`<div class="pc-abs">${abHtml}</div>`:''}
    `;
    el.appendChild(card);
  });
}

// ═══════════════════════════════════════════════
// ABILITY EDITOR
// ═══════════════════════════════════════════════
function openAE(pcId,abId){
  aePCId=pcId;
  aeAbId=(abId!=null)?abId:null;
  aeVarIdx=null;
  const pc=PC.find(c=>c.id===pcId);
  const src=aeAbId!==null?pc?.abilities.find(a=>a.id===aeAbId):null;
  _fillAE(pcId,aeAbId,src,null);
}
// Open AE to add a new variant (prefilled from base ability)
function openAEVariant(pcId,abId){
  aePCId=pcId;aeAbId=abId;aeVarIdx='new';
  const pc=PC.find(c=>c.id===pcId);
  const ab=pc?.abilities.find(a=>a.id===abId);
  _fillAE(pcId,abId,ab,null); // prefill from base
  document.getElementById('ae-title').textContent='ADD VARIANT';
  document.getElementById('ae-var-row').style.display='block';
  document.getElementById('ae-vartag').value='';
}
// Open AE to edit existing variant
function openAEEditVariant(pcId,abId,varIdx){
  aePCId=pcId;aeAbId=abId;aeVarIdx=varIdx;
  const pc=PC.find(c=>c.id===pcId);
  const ab=pc?.abilities.find(a=>a.id===abId);
  const vr=ab?.variants?.[varIdx];
  _fillAE(pcId,abId,vr,null);
  document.getElementById('ae-title').textContent='EDIT VARIANT';
  document.getElementById('ae-var-row').style.display='block';
  document.getElementById('ae-vartag').value=vr?.tag||'';
}
function _fillAE(pcId,abId,src,_unused){
  clearAE();setTab('ae','n');
  const pc=pcId!=='UA'?PC.find(c=>c.id===pcId):null;
  const hint=document.getElementById('ae-stat-hint');
  if(pc?.baseStat>0){hint.style.display='block';document.getElementById('ae-stat-val').textContent=pc.baseStat;}
  else hint.style.display='none';
  document.getElementById('ae-var-row').style.display='none';
  document.getElementById('ae-vartag').value='';
  if(src){
    if(aeVarIdx===null&&abId!==null)document.getElementById('ae-title').textContent='EDIT ABILITY';
    else if(aeVarIdx===null)document.getElementById('ae-title').textContent='ADD ABILITY';
    document.getElementById('ae-name').value=src.name||'';
    document.getElementById('ae-desc').value=src.desc||'';
    document.getElementById('ae-cast').value=src.castTime||'';
    document.getElementById('ae-cd').value=src.cooldown||'';
    document.getElementById('ae-hit').value=src.hitType||'single';
    const s=normDmgType(src.dmgType);
    setTab('ae',s);
    const fe=document.getElementById('ae-flat-'+s);if(fe&&src.dmgFlat!=null)fe.value=src.dmgFlat;
    if((src.mult||0)>0||(src.stat||0)>0||(src.b1||0)>0||(src.b2||0)>0){
      ['stat','mult','b1','b2'].forEach(k=>{const el=document.getElementById('ae-'+k+'-'+s);if(el)el.value=src[k]||0;});
      const adv=document.getElementById('ae-adv-'+s);
      const btn=document.getElementById('ae-advbtn-'+s);
      if(adv){adv.classList.add('on');if(btn)btn.textContent=btn.textContent.replace('▶','▼');}
      updAdv('ae',s);
    }
    if(s==='d')document.getElementById('ae-delay').value=src.delay||0;
    if(s==='t'){document.getElementById('ae-ticki').value=src.ticki||0;document.getElementById('ae-tickd').value=src.tickd||0;updDotPrev('ae');}
    document.getElementById('ae-effn').value=src.effName||'';
    document.getElementById('ae-effd').value=src.effDur||'';
    document.getElementById('ae-stacks').checked=src.stacks||false;
    document.getElementById('ae-cancrit').checked=src.canCrit||false;
    const stundmgEl=document.getElementById('ae-stundmg');
    if(stundmgEl)stundmgEl.value=src.stunDmg||'';
    if(pc)renderAERes(pc,src.resources);
    else{document.getElementById('ae-res-sec').classList.remove('on');}
  } else {
    document.getElementById('ae-title').textContent='ADD ABILITY';
    if(pc)renderAERes(pc,null);
    else document.getElementById('ae-res-sec').classList.remove('on');
  }
  openOv('ov-ae');
}
function clearAE(){
  ['ae-name','ae-desc','ae-effn','ae-vartag','ae-stundmg'].forEach(id=>document.getElementById(id).value='');
  ['ae-flat-n','ae-flat-d','ae-flat-t','ae-cast','ae-cd','ae-delay','ae-ticki','ae-tickd','ae-effd',
   'ae-stat-n','ae-mult-n','ae-b1-n','ae-b2-n','ae-stat-d','ae-mult-d','ae-b1-d','ae-b2-d',
   'ae-stat-t','ae-mult-t','ae-b1-t','ae-b2-t'].forEach(id=>{const el=document.getElementById(id);if(el)el.value='';});
  ['ae-prev-n','ae-prev-d','ae-prev-t','ae-dot-prev'].forEach(id=>{const el=document.getElementById(id);if(el)el.textContent='';});
  ['n','d','t'].forEach(s=>{
    const adv=document.getElementById('ae-adv-'+s);const btn=document.getElementById('ae-advbtn-'+s);
    if(adv)adv.classList.remove('on');if(btn)btn.textContent=btn.textContent.replace('▼','▶');
  });
  document.getElementById('ae-stacks').checked=false;
  document.getElementById('ae-cancrit').checked=false;
  document.getElementById('ae-res-sec').classList.remove('on');
}
function renderAERes(pc,savedRes){
  const sec=document.getElementById('ae-res-sec');
  const rows=document.getElementById('ae-res-rows');
  const ar=activeRes(pc);
  if(!ar.length){sec.classList.remove('on');return;}
  sec.classList.add('on');rows.innerHTML='';
  ar.forEach(r=>{
    const sv=savedRes?.[r.idx]||{};
    const row=document.createElement('div');row.className='ab-res-item';
    row.innerHTML=`
      <div class="ab-res-lbl">${r.name}</div>
      <input type="number" id="ae-ra-${r.idx}" min="0" placeholder="0" value="${sv.amount||''}"
        style="font-family:var(--mono);font-size:12px;padding:5px 7px;background:var(--bg);border:1px solid var(--border);color:var(--text);">
      <select id="ae-rm-${r.idx}" style="font-family:var(--mono);font-size:12px;padding:5px 7px;background:var(--bg);border:1px solid var(--border);color:var(--text);">
        <option value="" ${!sv.mode?'selected':''}>— none —</option>
        <option value="gain" ${sv.mode==='gain'?'selected':''}>Gain</option>
        <option value="cost" ${sv.mode==='cost'?'selected':''}>Cost</option>
      </select>
    `;
    rows.appendChild(row);
  });
}
function readAERes(pc){
  const ar=activeRes(pc);if(!ar.length)return null;
  const res=[null,null,null];
  ar.forEach(r=>{
    const amt=parseFloat(document.getElementById('ae-ra-'+r.idx)?.value)||0;
    const mode=document.getElementById('ae-rm-'+r.idx)?.value||'';
    if(mode&&amt>0)res[r.idx]={amount:amt,mode};
  });
  return res;
}
function confirmAE(){
  const name=document.getElementById('ae-name').value.trim();if(!name){alert('Name required.');return;}
  const s=normDmgType(aeTab);
  const flatRaw=document.getElementById('ae-flat-'+s)?.value??'';
  const abData={
    name,desc:document.getElementById('ae-desc').value.trim(),
    castTime:parseFloat(document.getElementById('ae-cast').value)||0,
    cooldown:parseFloat(document.getElementById('ae-cd').value)||0,
    hitType:document.getElementById('ae-hit').value,
    dmgType:s,
    dmgFlat:flatRaw!==''?parseFloat(flatRaw):null,
    dmg:null,
    stat:parseFloat(document.getElementById('ae-stat-'+s)?.value)||0,
    mult:parseFloat(document.getElementById('ae-mult-'+s)?.value)||0,
    b1:parseFloat(document.getElementById('ae-b1-'+s)?.value)||0,
    b2:parseFloat(document.getElementById('ae-b2-'+s)?.value)||0,
    delay:parseFloat(document.getElementById('ae-delay')?.value)||0,
    ticki:parseFloat(document.getElementById('ae-ticki')?.value)||0,
    tickd:parseFloat(document.getElementById('ae-tickd')?.value)||0,
    effName:document.getElementById('ae-effn').value.trim(),
    effDur:parseFloat(document.getElementById('ae-effd')?.value)||0,
    stacks:document.getElementById('ae-stacks').checked,
    canCrit:document.getElementById('ae-cancrit').checked,
    stunDmg:parseFloat(document.getElementById('ae-stundmg')?.value)||0,
  };
  if(aePCId==='UA'){
    // Save to universal abilities
    abData.resources=null;
    if(aeVarIdx!==null){
      const ab=UA.find(a=>a.id===aeAbId);if(!ab)return;
      if(!ab.variants)ab.variants=[];
      const tag=document.getElementById('ae-vartag').value.trim()||'Variant';
      const varData={...abData,tag};
      if(aeVarIdx==='new')ab.variants.push(varData);
      else ab.variants[aeVarIdx]=varData;
    } else {
      if(aeAbId!=null){
        const ab=UA.find(a=>a.id===aeAbId);
        if(ab){const variants=ab.variants;Object.assign(ab,abData);ab.variants=variants||[];ab.visible=ab.visible!==false;}
      } else {
        UA.push({id:nextUAId++,...abData,variants:[],visible:true,cdLinked:true});
      }
    }
    saveUA();closeOv('ov-ae');renderUAList();updateUAToggle();
  } else {
    // Save to preset character ability
    const pc=PC.find(c=>c.id===aePCId);if(!pc)return;
    abData.resources=readAERes(pc);
    if(aeVarIdx!==null){
      const ab=pc.abilities.find(a=>a.id===aeAbId);if(!ab)return;
      if(!ab.variants)ab.variants=[];
      const tag=document.getElementById('ae-vartag').value.trim()||'Variant';
      const varData={...abData,tag};
      if(aeVarIdx==='new')ab.variants.push(varData);
      else ab.variants[aeVarIdx]=varData;
    } else {
      if(aeAbId!==null){
        const ab=pc.abilities.find(a=>a.id===aeAbId);
        if(ab){const variants=ab.variants;Object.assign(ab,abData);ab.variants=variants||[];}
      } else {
        pc.abilities.push({id:nextAbId++,...abData,variants:[]});
      }
    }
    savePresets();closeOv('ov-ae');renderLibrary();
  }
}
function delAb(pcId,abId){showCF('DELETE ABILITY','Remove this ability and all its variants?',()=>{const pc=PC.find(c=>c.id===pcId);if(pc)pc.abilities=pc.abilities.filter(a=>a.id!==abId);savePresets();renderLibrary();});}
function delVariant(pcId,abId,varIdx){showCF('DELETE VARIANT','Remove this variant?',()=>{const pc=PC.find(c=>c.id===pcId);const ab=pc?.abilities.find(a=>a.id===abId);if(ab?.variants)ab.variants.splice(varIdx,1);savePresets();renderLibrary();});}
function toggleCDLink(pcId,abId){
  const pc=PC.find(c=>c.id===pcId);if(!pc)return;
  const ab=pc.abilities.find(a=>a.id===abId);if(!ab)return;
  ab.cdLinked=(ab.cdLinked===false)?true:false; // default true, toggle
  savePresets();renderLibrary();
}

// ═══════════════════════════════════════════════
// DMG TABS & ADVANCED DMG
// ═══════════════════════════════════════════════
function setTab(scope,t){
  const pfx=scope;
  document.querySelectorAll('#'+pfx+'-tabs .dt').forEach(el=>el.classList.toggle('on',el.dataset.t===t));
  ['n','d','t'].forEach(s=>{const el=document.getElementById(pfx+'-dtf-'+s);if(el)el.classList.toggle('on',s===t);});
  if(scope==='lm')lmTab=t;else aeTab=t;
}
function toggleAdv(scope,s){
  const adv=document.getElementById(scope+'-adv-'+s);
  const btn=document.getElementById(scope+'-advbtn-'+s);
  if(!adv)return;
  const open=adv.classList.toggle('on');
  if(btn)btn.textContent=btn.textContent.replace(open?'▶':'▼',open?'▼':'▶');
}
function getLMBaseStat(){
  const charList=lmMode.startsWith('battle')?bChars:chars;
  const idx=parseInt(document.getElementById('lm-char').value)||0;
  const c=charList[idx];if(!c?.presetId)return 0;return getBaseStat(c.presetId);
}
function updAdv(scope,s){
  const p=scope+'-',cbs=scope==='lm'?getLMBaseStat():(PC.find(c=>c.id===aePCId)?.baseStat||0);
  const bonus=parseFloat(document.getElementById(p+'stat-'+s).value)||0;
  const mult=parseFloat(document.getElementById(p+'mult-'+s).value)||0;
  const b1=parseFloat(document.getElementById(p+'b1-'+s).value)||0;
  const b2=parseFloat(document.getElementById(p+'b2-'+s).value)||0;
  const el=document.getElementById(p+'prev-'+s);if(!el)return;
  const total=bonus+cbs;
  if(total>0&&mult>0){
    const r=Math.round(total*(mult/100)*(1+b1/100)*(1+b2/100));
    const sStr=cbs>0?`(${cbs}+${bonus}=${total})`:`${total}`;
    el.textContent=`= ${r}  [${sStr}×${mult}%${b1?'×(1+'+b1+'%)':''}${b2?'×(1+'+b2+'%)':''}]`;
  } else el.textContent='';
}
function refreshAdvPrev(){['n','d','t'].forEach(s=>updAdv('lm',s));}
function updDotPrev(scope){
  const p=scope+'-';
  const dmg=parseFloat(document.getElementById(p+'flat-t').value)||parseFloat(document.getElementById(p+'stat-t').value)||0;
  const iv=parseFloat(document.getElementById(p+'ticki').value)||0;
  const dur=parseFloat(document.getElementById(p+'tickd').value)||0;
  const el=document.getElementById(p+'dot-prev');if(!el)return;
  if(iv>0&&dur>0){const t=Math.floor(dur/iv);el.textContent=`${t} ticks`;}else el.textContent='';
}

