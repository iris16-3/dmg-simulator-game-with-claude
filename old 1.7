<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DMG CALC</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@400;600;700&display=swap');
:root{
  --bg:#0d0d0d;--surface:#141414;--s2:#1a1a1a;--border:#2a2a2a;
  --y:#f5c400;--yd:#b38f00;--yb:rgba(245,196,0,0.07);
  --red:#c0392b;--green:#27ae60;--blue:#2980b9;
  --text:#e8e8e8;--muted:#666;
  --mono:'Share Tech Mono',monospace;--sans:'Rajdhani',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:15px;min-height:100vh;}

/* inputs */
input[type=text],input[type=number],textarea,select{
  background:var(--bg);border:1px solid var(--border);color:var(--text);
  font-family:var(--mono);font-size:13px;padding:7px 10px;width:100%;outline:none;
  transition:border-color .15s;
}
input:focus,textarea:focus,select:focus{border-color:var(--y);}
textarea{resize:vertical;min-height:54px;}
select option{background:var(--bg);}
.cb-row{display:flex;align-items:center;gap:8px;margin-top:4px;}
.cb-row input[type=checkbox]{width:16px;height:16px;accent-color:var(--y);cursor:pointer;}
.cb-row label{font-family:var(--mono);font-size:11px;color:var(--muted);letter-spacing:1px;cursor:pointer;margin:0;}

/* buttons */
.btn{font-family:var(--mono);font-size:13px;letter-spacing:2px;text-transform:uppercase;padding:9px 18px;border:none;cursor:pointer;transition:opacity .15s;}
.btn:hover{opacity:.8;}.btn:active{opacity:.6;}
.btn-y  {background:var(--y);color:#000;font-weight:bold;}
.btn-ys {background:transparent;color:var(--y);border:1px solid var(--y);}
.btn-r  {background:transparent;color:var(--red);border:1px solid var(--red);}
.btn-g  {background:var(--green);color:#fff;font-weight:bold;}
.btn-gh {background:transparent;color:var(--muted);border:1px solid var(--border);}
.btn-bl {background:transparent;color:#5dade2;border:1px solid #5dade2;}
.btn-sm{font-size:11px;padding:5px 10px;letter-spacing:1px;}
.btn-xs{font-size:10px;padding:3px 8px;letter-spacing:1px;}

/* ── SETUP ── */
#setup{display:flex;flex-direction:column;align-items:center;padding:40px 20px 60px;gap:20px;min-height:100vh;}
.setup-pair{display:flex;gap:20px;flex-wrap:wrap;width:100%;max-width:1100px;justify-content:center;}
.sbox{background:var(--surface);border:1px solid var(--border);padding:28px 32px;width:100%;max-width:520px;}
.sbox.ytop{border-top:3px solid var(--y);}
.sbox.btop{border-top:3px solid #5dade2;}
.sbox h1{font-family:var(--mono);font-size:20px;color:var(--y);letter-spacing:4px;text-transform:uppercase;margin-bottom:4px;}
.sbox h2{font-family:var(--mono);font-size:13px;color:#5dade2;letter-spacing:3px;text-transform:uppercase;margin-bottom:16px;}
.sbox .sub{font-family:var(--mono);font-size:11px;color:var(--muted);letter-spacing:2px;margin-bottom:24px;}
.frow{margin-bottom:14px;}
.frow>label,.flbl{display:block;font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:5px;}
.fhint{font-family:var(--mono);font-size:10px;color:var(--muted);margin-top:5px;letter-spacing:1px;}
.finputs{display:flex;flex-direction:column;gap:7px;}
.srow{display:flex;gap:8px;align-items:center;}
.srow input{flex:1;}

/* preset library */
.lib-add{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:6px;}
.lib-add input[placeholder="#ID"]{width:60px;flex-shrink:0;}
.lib-add input[placeholder="Name…"]{flex:1;min-width:80px;}
.lib-add input[placeholder="Base Stat"]{width:90px;flex-shrink:0;}
.pc-list{display:flex;flex-direction:column;gap:8px;margin-top:8px;}
.pc-card{background:var(--bg);border:1px solid var(--border);padding:10px 12px;}
.pc-head{display:flex;flex-direction:column;gap:6px;}
.pc-meta{display:flex;flex-direction:column;gap:2px;}
.pc-id{font-family:var(--mono);font-size:10px;color:var(--yd);letter-spacing:2px;}
.pc-nm{font-family:var(--mono);font-size:13px;color:var(--text);word-break:break-word;}
.pc-nm-edit{display:none;font-family:var(--mono);font-size:13px;width:100%;}
.pc-nm-edit.on{display:block;}
.pc-desc{font-family:var(--mono);font-size:10px;color:var(--muted);font-style:italic;margin-top:2px;white-space:pre-wrap;word-break:break-word;}
.pc-acts{display:flex;gap:4px;flex-wrap:wrap;}
.pc-abs{margin-top:8px;border-top:1px solid var(--border);padding-top:8px;display:flex;flex-direction:column;gap:6px;}
.ab-row{display:flex;flex-direction:column;gap:5px;}
.ab-info{display:flex;flex-direction:column;gap:2px;}
.ab-name{font-family:var(--mono);font-size:12px;color:var(--y);word-break:break-word;}
.ab-meta{font-family:var(--mono);font-size:11px;color:var(--muted);white-space:pre-wrap;word-break:break-word;}
.ab-acts{display:flex;gap:4px;}
.pc-no-ab{font-family:var(--mono);font-size:11px;color:var(--muted);font-style:italic;}

/* ── UNIVERSAL PANEL ── */
#ua-toggle{position:fixed;right:0;top:50%;transform:translateY(-50%);z-index:400;background:var(--surface);border:1px solid var(--border);border-right:none;color:var(--muted);font-family:var(--mono);font-size:13px;padding:12px 6px;cursor:pointer;writing-mode:vertical-rl;letter-spacing:2px;transition:color .15s,border-color .15s;display:none;}
#ua-toggle:hover{color:#27ae60;border-color:#27ae60;}
#ua-toggle.visible{display:block;}
#ua-panel{position:fixed;right:0;top:0;bottom:0;width:340px;background:var(--surface);border-left:1px solid var(--border);z-index:410;display:flex;flex-direction:column;transform:translateX(100%);transition:transform .2s ease;}
#ua-panel.open{transform:translateX(0);}
.ua-row{background:var(--bg);border:1px solid var(--border);border-left:3px solid #27ae60;padding:10px 12px;display:flex;flex-direction:column;gap:5px;margin-bottom:6px;}
.ua-nm{font-family:var(--mono);font-size:13px;color:var(--text);}
.ua-meta{font-family:var(--mono);font-size:11px;color:var(--muted);}
.ua-acts{display:flex;gap:5px;flex-wrap:wrap;align-items:center;}
.ua-vis-btn{font-family:var(--mono);font-size:10px;padding:2px 7px;background:var(--bg);border:1px solid var(--border);color:var(--muted);cursor:pointer;letter-spacing:1px;}
.ua-vis-btn.on{border-color:#27ae60;color:#27ae60;}
.ua-var-row{background:var(--s2);border:1px solid var(--border);border-left:2px solid #8e44ad;padding:7px 10px;margin-top:4px;}
.cpbox{background:var(--surface);border:1px solid var(--border);border-top:3px solid #27ae60;padding:24px 28px;max-width:380px;width:100%;}
.cpbox h3{font-family:var(--mono);font-size:13px;color:#27ae60;letter-spacing:3px;text-transform:uppercase;margin-bottom:14px;}
.cp-list{display:flex;flex-direction:column;gap:7px;margin-bottom:16px;}
.cp-btn{background:var(--bg);border:1px solid var(--border);padding:10px 14px;cursor:pointer;text-align:left;font-family:var(--mono);font-size:13px;color:var(--text);}
.cp-btn:hover{border-color:#27ae60;color:#27ae60;}

.crit-tag{font-family:var(--mono);font-size:10px;color:#e74c3c;border:1px solid #e74c3c;padding:1px 5px;margin-left:4px;letter-spacing:1px;}
.crit-row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:6px;}
.crit-stat{font-family:var(--mono);font-size:10px;color:var(--muted);margin-bottom:8px;}
.crit-stat span{color:var(--y);}
/* ── ENEMY EDITOR ── */
.ec{cursor:pointer;transition:border-color .15s;}
.ec:not(.dead):hover{border-color:#5dade2;}
.ec.stunned{border-color:#f39c12;border-width:2px;}
.stun-bar-wrap{height:4px;background:var(--border);margin-top:3px;}
.stun-bar{height:100%;background:#f39c12;transition:width .3s;}
.stun-tag{font-family:var(--mono);font-size:9px;color:#f39c12;letter-spacing:2px;margin-top:2px;}
.res-tag{font-family:var(--mono);font-size:9px;color:var(--muted);margin-top:1px;}

/* ── VARIANTS ── */
.var-list{display:flex;flex-direction:column;gap:4px;margin-top:6px;padding-top:6px;border-top:1px solid var(--border);}
.var-row{display:flex;flex-direction:column;gap:4px;background:var(--bg);border:1px solid var(--border);border-left:2px solid #8e44ad;padding:7px 10px;}
.var-tag{font-family:var(--mono);font-size:9px;color:#8e44ad;letter-spacing:2px;text-transform:uppercase;}
.var-nm{font-family:var(--mono);font-size:12px;color:var(--text);}
.var-meta{font-family:var(--mono);font-size:11px;color:var(--muted);}
.var-acts{display:flex;gap:4px;}
/* PP cycle button */
.cycle-btn{font-family:var(--mono);font-size:11px;padding:2px 7px;background:var(--bg);border:1px solid #8e44ad;color:#8e44ad;cursor:pointer;letter-spacing:1px;}
.cycle-btn:hover{border-color:#b86ecd;color:#b86ecd;}
.var-badge{font-family:var(--mono);font-size:10px;color:#8e44ad;border:1px solid #8e44ad;padding:1px 5px;margin-left:4px;letter-spacing:1px;}

/* ── NOTES ── */
#note-toggle{position:fixed;left:0;top:50%;transform:translateY(-50%);z-index:400;background:var(--surface);border:1px solid var(--border);border-left:none;color:var(--muted);font-family:var(--mono);font-size:13px;padding:12px 6px;cursor:pointer;writing-mode:vertical-rl;letter-spacing:2px;transition:color .15s,border-color .15s;}
#note-toggle:hover{color:var(--y);border-color:var(--yd);}
#note-panel{position:fixed;left:0;top:0;bottom:0;width:320px;background:var(--surface);border-right:1px solid var(--border);z-index:410;display:flex;flex-direction:column;transform:translateX(-100%);transition:transform .2s ease;}
#note-panel.open{transform:translateX(0);}
.note-panel-head{padding:14px 16px;border-bottom:1px solid var(--border);display:flex;flex-direction:column;gap:8px;flex-shrink:0;}
.note-panel-title{font-family:var(--mono);font-size:12px;color:var(--y);letter-spacing:3px;text-transform:uppercase;display:flex;align-items:center;justify-content:space-between;}
.note-sel-row{display:flex;gap:6px;align-items:center;}
.note-sel-row select{flex:1;}
.note-body{flex:1;overflow:hidden;display:flex;flex-direction:column;padding:12px 16px;gap:8px;}
.note-name-row{display:flex;gap:6px;align-items:center;}
.note-name-row input{flex:1;font-family:var(--mono);font-size:12px;}
#note-textarea{flex:1;resize:none;font-family:var(--mono);font-size:12px;background:var(--bg);border:1px solid var(--border);color:var(--text);padding:10px;outline:none;line-height:1.6;white-space:pre-wrap;}
#note-textarea:focus{border-color:var(--y);}
#note-textarea[readonly]{color:var(--muted);cursor:default;}
.note-add-row{display:flex;gap:6px;align-items:center;padding:10px 16px;border-top:1px solid var(--border);flex-shrink:0;}
.note-add-row input{flex:1;font-family:var(--mono);font-size:12px;}

/* ── APP / BATTLE SCREENS ── */
#app,#battle{display:none;flex-direction:column;height:100vh;overflow:hidden;}
.topbar{background:var(--surface);border-bottom:1px solid var(--border);padding:12px 18px;flex-shrink:0;}
.topbar-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;gap:8px;flex-wrap:wrap;}
.screen-title{font-family:var(--mono);font-size:13px;color:var(--y);letter-spacing:3px;}
.screen-title.blue{color:#5dade2;}
.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-bottom:10px;}
.sc{background:var(--s2);padding:9px 12px;text-align:center;}
.sc .l{font-family:var(--mono);font-size:9px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:2px;}
.sc .v{font-family:var(--mono);font-size:17px;color:var(--y);font-weight:bold;}
#csg,#bcsg{display:flex;gap:8px;flex-wrap:wrap;}
.csc{background:var(--bg);border:1px solid var(--border);padding:7px 10px;flex:1;min-width:100px;}
.csc.preset{cursor:pointer;border-color:var(--yd);}
.csc.preset:hover{border-color:var(--y);}
.csc .cn{font-family:var(--mono);font-size:10px;color:var(--yd);letter-spacing:1px;text-transform:uppercase;margin-bottom:5px;border-bottom:1px solid var(--border);padding-bottom:3px;display:flex;align-items:center;gap:5px;}
.pbadge{font-family:var(--mono);font-size:9px;color:var(--y);border:1px solid var(--yd);padding:1px 4px;}
.cr{display:flex;justify-content:space-between;margin-bottom:1px;}
.cr span{font-family:var(--mono);font-size:11px;color:var(--muted);}
.cr strong{font-family:var(--mono);font-size:11px;color:var(--text);}
.tap-hint{font-family:var(--mono);font-size:9px;color:var(--yd);margin-top:4px;letter-spacing:1px;}
.res-bar{border-top:1px solid var(--border);margin-top:5px;padding-top:5px;display:flex;flex-direction:column;gap:2px;}
.res-row{display:flex;justify-content:space-between;}
.res-nm{font-family:var(--mono);font-size:10px;color:var(--muted);}
.res-vl{font-family:var(--mono);font-size:10px;color:var(--y);}

#fx-bar,#bfx-bar{background:var(--bg);border-top:1px solid var(--border);padding:6px 18px;display:flex;gap:8px;flex-wrap:wrap;flex-shrink:0;min-height:32px;align-items:center;}
.fx-lbl{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;}
.fx-chip{font-family:var(--mono);font-size:11px;padding:2px 7px;border:1px solid var(--yd);color:var(--y);background:var(--yb);}

#log-area,#battle-log{flex:1;overflow-y:auto;padding:14px 18px;display:flex;flex-direction:column;gap:7px;}
#log-area::-webkit-scrollbar,#battle-log::-webkit-scrollbar{width:4px;}
#log-area::-webkit-scrollbar-thumb,#battle-log::-webkit-scrollbar-thumb{background:var(--border);}
.empty-log{font-family:var(--mono);font-size:12px;color:var(--muted);text-align:center;margin-top:40px;letter-spacing:2px;}
.botbar{background:var(--surface);border-top:1px solid var(--border);padding:10px 18px;display:flex;gap:10px;align-items:center;flex-shrink:0;}

/* battle top */
#battle-top{background:var(--surface);border-bottom:1px solid var(--border);padding:12px 18px;flex-shrink:0;}
.btop-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;gap:8px;}
.timer{font-family:var(--mono);font-size:20px;font-weight:bold;color:var(--y);}
.timer.urgent{color:var(--red);}
#enemy-grid{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px;}
.ec{background:var(--bg);border:1px solid var(--border);padding:7px 10px;flex:1;min-width:100px;}
.ec.dead{opacity:.4;border-style:dashed;}
.ec .en{font-family:var(--mono);font-size:10px;color:#5dade2;letter-spacing:1px;text-transform:uppercase;margin-bottom:3px;}
.ec .ehp{font-family:var(--mono);font-size:12px;color:var(--text);margin-bottom:3px;}
.hpw{height:5px;background:var(--border);}
.hpb{height:100%;background:var(--green);}
.hpb.mid{background:#e67e22;}.hpb.low{background:var(--red);}
.dead-lbl{font-family:var(--mono);font-size:9px;color:var(--red);letter-spacing:2px;margin-top:2px;}
#battle-bottom{background:var(--surface);border-top:1px solid var(--border);padding:10px 18px;flex-shrink:0;}
#bcsg{margin-bottom:8px;}

/* log entries */
.le{background:var(--surface);border:1px solid var(--border);border-left:3px solid var(--yd);padding:11px 13px;}
.le.editing{border-left-color:var(--y);background:var(--s2);}
.le.ble{border-left-color:#5dade2;}
.le-head{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:5px;flex-wrap:wrap;}
.le-l{display:flex;flex-direction:column;gap:1px;}
.le-char{font-family:var(--mono);font-size:10px;color:var(--y);letter-spacing:2px;text-transform:uppercase;}
.le-name{font-family:var(--mono);font-size:13px;color:var(--text);}
.le-meta{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:5px;}
.mp{font-family:var(--mono);font-size:11px;color:var(--muted);}
.mp span{color:var(--text);}
.mp.dmg span{color:var(--y);font-size:13px;font-weight:bold;}
.le-desc{font-family:var(--mono);font-size:11px;color:var(--muted);margin-bottom:4px;font-style:italic;white-space:pre-wrap;word-break:break-word;}
.le-dmt{font-family:var(--mono);font-size:11px;margin-bottom:4px;}
.dmt-d{color:#e67e22;}.dmt-dot{color:#8e44ad;}
.le-eff{font-family:var(--mono);font-size:11px;color:var(--yd);margin-bottom:4px;}
.le-tgt{font-family:var(--mono);font-size:10px;color:#5dade2;margin-bottom:4px;}
.le-acts{display:flex;gap:5px;flex-wrap:wrap;}
.cdb{font-family:var(--mono);font-size:10px;padding:2px 7px;letter-spacing:1px;}
.cdb.rdy{color:var(--green);border:1px solid var(--green);}
.cdb.cool{color:var(--red);border:1px solid var(--red);}
.ef{margin-top:10px;border-top:1px solid var(--border);padding-top:10px;display:none;}
.ef.open{display:block;}
.eg{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;}
.eg .full{grid-column:1/-1;}
.ef label{display:block;font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:3px;}
.ea{display:flex;gap:7px;}

/* dmg type tabs */
.dtt{display:flex;margin-bottom:10px;}
.dt{font-family:var(--mono);font-size:11px;letter-spacing:1px;text-transform:uppercase;padding:5px 12px;border:1px solid var(--border);background:var(--bg);color:var(--muted);cursor:pointer;flex:1;text-align:center;}
.dt:not(:last-child){border-right:none;}
.dt.on{background:var(--yb);color:var(--y);border-color:var(--yd);}
.dtf{display:none;}.dtf.on{display:block;}
.adv-btn{font-family:var(--mono);font-size:10px;color:var(--yd);background:none;border:none;cursor:pointer;padding:0;letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;}
.adv-btn:hover{color:var(--y);}
.adv-fields{display:none;}.adv-fields.on{display:block;}
.adv-prev{font-family:var(--mono);font-size:11px;color:var(--y);margin-top:4px;min-height:16px;}
.adv-note{font-family:var(--mono);font-size:10px;color:var(--muted);margin-bottom:8px;}

/* modals */
.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.82);align-items:center;justify-content:center;padding:20px;}
.ov.on{display:flex;}
#ov-log{z-index:150;}
#ov-ae{z-index:200;}
#ov-epc{z-index:250;}
#ov-target{z-index:300;}
#ov-alert{z-index:300;}
#ov-rw{z-index:300;}
#ov-reset{z-index:300;}
#ov-breset{z-index:300;}
#ov-cf{z-index:300;}
#ov-result{z-index:300;}
#pp{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.82);z-index:120;align-items:flex-end;justify-content:center;}
#pp.on{display:flex;}
.mbox{background:var(--surface);border:1px solid var(--border);border-top:3px solid var(--y);padding:26px 30px;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;}
.mbox::-webkit-scrollbar{width:4px;}
.mbox::-webkit-scrollbar-thumb{background:var(--border);}
.mbox h2{font-family:var(--mono);font-size:13px;color:var(--y);letter-spacing:3px;text-transform:uppercase;margin-bottom:18px;}
.mg{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;}
.mg .full{grid-column:1/-1;}
.mbox label{display:block;font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;}
.ma{display:flex;gap:8px;margin-top:16px;}
.sdiv{border:none;border-top:1px solid var(--border);margin:14px 0 10px;}
.slbl{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:10px;}
.warn-box{background:var(--surface);border:1px solid var(--red);border-top:3px solid var(--red);padding:24px 28px;max-width:400px;width:100%;}
.warn-box.yw{border-color:var(--y);border-top-color:var(--y);}
.warn-box h3{font-family:var(--mono);font-size:13px;color:var(--red);letter-spacing:3px;text-transform:uppercase;margin-bottom:10px;}
.warn-box.yw h3{color:var(--y);}
.warn-box p{font-family:var(--mono);font-size:12px;color:var(--text);margin-bottom:18px;line-height:1.7;white-space:pre-line;}
.warn-acts{display:flex;gap:8px;flex-wrap:wrap;}
.result-box{background:var(--surface);border:1px solid var(--y);border-top:3px solid var(--y);padding:28px 32px;max-width:380px;width:100%;}
.result-box.lose{border-color:var(--red);border-top-color:var(--red);}
.result-box h3{font-family:var(--mono);font-size:14px;color:var(--y);letter-spacing:3px;text-transform:uppercase;margin-bottom:12px;}
.result-box.lose h3{color:var(--red);}
.result-box p{font-family:var(--mono);font-size:12px;color:var(--text);margin-bottom:20px;line-height:1.7;white-space:pre-line;}

/* target picker */
.pp-box{background:var(--surface);border:1px solid var(--border);border-top:3px solid var(--y);padding:20px 24px;width:100%;max-width:560px;max-height:75vh;display:flex;flex-direction:column;}
.pp-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;flex-shrink:0;}
.pp-head h3{font-family:var(--mono);font-size:13px;color:var(--y);letter-spacing:3px;text-transform:uppercase;}
.pp-list{overflow-y:auto;display:flex;flex-direction:column;gap:7px;flex:1;}
.pp-row{background:var(--bg);border:1px solid var(--border);padding:9px 11px;display:flex;align-items:flex-start;justify-content:space-between;gap:10px;flex-wrap:wrap;}
.pp-ab-nm{font-family:var(--mono);font-size:13px;color:var(--text);}
.pp-ab-meta{font-family:var(--mono);font-size:11px;color:var(--muted);white-space:pre-wrap;word-break:break-word;}
.pp-right{display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;}
.pp-no-ab{font-family:var(--mono);font-size:12px;color:var(--muted);text-align:center;padding:18px;font-style:italic;}
.pp-res-hdr{background:var(--bg);border:1px solid var(--border);border-left:3px solid var(--yd);padding:9px 12px;margin-bottom:7px;}
.pp-res-title{font-family:var(--mono);font-size:10px;color:var(--yd);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px;}
.pp-res-item{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:5px;}
.pp-res-lbl{font-family:var(--mono);font-size:11px;color:var(--muted);flex:1;}
.pp-res-cnt{font-family:var(--mono);font-size:13px;color:var(--y);min-width:40px;}
.pp-res-btns{display:flex;gap:4px;align-items:center;}
.pp-res-btns button{font-family:var(--mono);font-size:13px;width:26px;height:26px;border:1px solid var(--border);background:var(--bg);color:var(--text);cursor:pointer;}
.pp-res-btns button:hover{border-color:var(--y);color:var(--y);}
.pp-res-btns input{width:44px;text-align:center;font-family:var(--mono);font-size:12px;padding:3px 5px;}
.tgt-list{display:flex;flex-direction:column;gap:8px;}
.tgt-btn{background:var(--bg);border:1px solid var(--border);padding:12px 16px;cursor:pointer;text-align:left;width:100%;transition:border-color .15s;}
.tgt-btn:hover{border-color:var(--y);}
.tgt-nm{font-family:var(--mono);font-size:13px;color:var(--text);}
.tgt-hp{font-family:var(--mono);font-size:11px;color:var(--muted);margin-top:2px;}
/* ability editor resource rows */
.ab-res-section{display:none;}
.ab-res-section.on{display:block;}
.ab-res-item{display:grid;grid-template-columns:1fr 80px 110px;gap:7px;align-items:center;margin-bottom:7px;}
.ab-res-lbl{font-family:var(--mono);font-size:11px;color:var(--text);}
</style>
</head>
<body>

<!-- SETUP -->
<div id="setup">
<div class="setup-pair">
<!-- DMG CALC BOX -->
<div class="sbox ytop">
  <h1>DMG CALC</h1>
  <div class="sub">// damage log &amp; tracker</div>
  <div class="frow">
    <label>Characters</label>
    <div class="srow" style="margin-bottom:6px">
      <input type="number" id="cc" min="1" max="10" value="1" style="width:60px">
      <button class="btn btn-ys btn-sm" onclick="setCC()">SET</button>
    </div>
    <div class="finputs" id="cc-inputs"><input type="text" placeholder="Name or #ID"></div>
    <div class="fhint">// plain name = regular · #ID = load preset</div>
  </div>
  <button class="btn btn-y" style="width:100%;margin-top:6px" onclick="startCalc()">START SESSION</button>
</div>
<!-- BATTLE BOX -->
<div class="sbox btop">
  <h2>BATTLE SESSION</h2>
  <div class="frow">
    <label>Characters</label>
    <div class="srow" style="margin-bottom:6px">
      <input type="number" id="bc" min="1" max="10" value="1" style="width:60px">
      <button class="btn btn-bl btn-sm" onclick="setBC()">SET</button>
    </div>
    <div class="finputs" id="bc-inputs"><input type="text" placeholder="Name or #ID"></div>
  </div>
  <div class="frow">
    <label>Enemies</label>
    <div class="srow" style="margin-bottom:6px">
      <input type="number" id="ec" min="1" max="20" value="1" style="width:60px">
      <button class="btn btn-bl btn-sm" onclick="setEC()">SET</button>
    </div>
    <div class="finputs" id="ec-inputs">
      <div class="srow"><input type="text" placeholder="Enemy name" style="flex:1"><input type="number" placeholder="HP" style="width:80px;flex-shrink:0" value="100"></div>
    </div>
  </div>
  <div class="frow">
    <label>Time Limit (s) <span style="color:var(--muted)">— cast-time based, leave empty = ∞</span></label>
    <input type="number" id="bc-timer" min="1" placeholder="e.g. 60">
  </div>
  <button class="btn btn-bl" style="width:100%;margin-top:6px;color:#fff;background:#2980b9;border:none;font-weight:bold" onclick="startBattle()">START BATTLE</button>
</div>
</div>

<!-- PRESET LIBRARY -->
<div class="sbox ytop" style="max-width:1100px;width:100%">
  <h2 style="color:var(--yd)">PRESET CHARACTERS</h2>
  <div class="lib-add">
    <input type="text" id="np-id" placeholder="#ID" style="width:60px;flex-shrink:0">
    <input type="text" id="np-name" placeholder="Name…" style="flex:1;min-width:80px">
    <input type="number" id="np-stat" placeholder="Base Stat" min="0" style="width:90px;flex-shrink:0">
    <button class="btn btn-ys btn-sm" onclick="addPC()">+ ADD</button>
  </div>
  <input type="text" id="np-desc" placeholder="Description (optional)" style="width:100%;margin-bottom:10px">
  <div class="pc-list" id="pc-list"><div style="font-family:var(--mono);font-size:11px;color:var(--muted);text-align:center;padding:10px">// no preset characters yet</div></div>
</div>

<!-- UNIVERSAL ABILITIES SECTION -->
<div class="sbox ytop" style="max-width:1100px;width:100%">
  <h2 style="color:#27ae60">UNIVERSAL ABILITIES</h2>
  <div style="font-family:var(--mono);font-size:10px;color:var(--muted);margin-bottom:12px;letter-spacing:1px">// usable by any character in any session · toggle visibility per ability</div>
  <div style="display:flex;gap:8px;margin-bottom:10px">
    <button class="btn btn-sm" style="background:var(--green);color:#fff;font-weight:bold;border:none" onclick="openUAModal(null)">+ ADD UNIVERSAL ABILITY</button>
  </div>
  <div class="pc-list" id="ua-list"><div style="font-family:var(--mono);font-size:11px;color:var(--muted);text-align:center;padding:10px">// no universal abilities yet</div></div>
</div>
</div>

<!-- UNIVERSAL PANEL BUTTON (right side, always visible in session) -->
<button id="ua-toggle" onclick="toggleUAPanel()">UNIVERSAL</button>

<!-- UNIVERSAL PANEL -->
<div id="ua-panel">
  <div class="note-panel-head">
    <div class="note-panel-title">
      <span style="color:#27ae60">// UNIVERSAL</span>
      <button class="btn btn-gh btn-xs" onclick="toggleUAPanel()">✕</button>
    </div>
    <div style="font-family:var(--mono);font-size:10px;color:var(--muted);margin-top:4px">Select ability then pick which character performs it.</div>
  </div>
  <div class="pp-list" id="ua-panel-list" style="padding:10px 14px;overflow-y:auto;flex:1"></div>
</div>

<!-- DMG CALC APP -->
<div id="app">
  <div class="topbar">
    <div class="topbar-row">
      <div class="screen-title">// DMG CALC</div>
      <button class="btn btn-r btn-sm" onclick="openOv('ov-reset')">RESET</button>
    </div>
    <div class="stats-grid">
      <div class="sc"><div class="l">Time</div><div class="v" id="s-time">0.00s</div></div>
      <div class="sc"><div class="l">DMG</div><div class="v" id="s-dmg">0</div></div>
      <div class="sc"><div class="l">DPS</div><div class="v" id="s-dps">0.00</div></div>
    </div>
    <div id="csg"></div>
  </div>
  <div id="fx-bar"><span class="fx-lbl">EFFECTS:</span><span id="fx-list" style="font-family:var(--mono);font-size:11px;color:var(--muted)">none</span></div>
  <div id="log-area"><div class="empty-log">// no abilities logged yet</div></div>
  <div class="botbar"><button class="btn btn-y" onclick="openLogModal('add')">+ LOG ABILITY</button></div>
</div>

<!-- BATTLE APP -->
<div id="battle">
  <div id="battle-top">
    <div class="btop-row">
      <div class="screen-title blue">// BATTLE</div>
      <div class="timer" id="btimer">∞</div>
      <button class="btn btn-r btn-sm" onclick="openOv('ov-breset')">END BATTLE</button>
    </div>
    <div id="enemy-grid"></div>
    <div id="bfx-bar"><span class="fx-lbl">EFFECTS:</span><span id="bfx-list" style="font-family:var(--mono);font-size:11px;color:var(--muted)">none</span></div>
  </div>
  <div id="battle-log"><div class="empty-log">// no actions yet</div></div>
  <div id="battle-bottom">
    <div id="bcsg" style="margin-bottom:8px"></div>
    <div class="botbar" style="border:none;padding:0"><button class="btn btn-bl" style="color:#fff;background:#2980b9;border:none;font-weight:bold" onclick="openLogModal('battle-add')">+ LOG ABILITY</button></div>
  </div>
</div>

<!-- LOG MODAL -->
<div class="ov" id="ov-log">
<div class="mbox">
  <h2 id="lm-title">LOG ABILITY</h2>
  <div class="mg">
    <div class="full"><label>Character</label><select id="lm-char" onchange="refreshAdvPrev()"></select></div>
    <div class="full"><label>Ability Name</label><input type="text" id="lm-name" placeholder="e.g. Shot"></div>
    <div class="full"><label>Description</label><textarea id="lm-desc"></textarea></div>
    <div><label>Cast Time (s)</label><input type="number" id="lm-cast" min="0" step="0.1" placeholder="0"></div>
    <div><label>Cooldown (s)</label><input type="number" id="lm-cd" min="0" step="0.1" placeholder="0"></div>
    <div class="full"><label>Hit Type</label><select id="lm-hit"><option value="single">Single Target</option><option value="multi">Multi Hit (all enemies)</option></select></div>
  </div>
  <hr class="sdiv"><div class="slbl">Damage Type</div>
  <div class="dtt" id="lm-tabs">
    <div class="dt on" data-t="n" onclick="setTab('lm','n')">NORMAL</div>
    <div class="dt" data-t="d" onclick="setTab('lm','d')">DELAYED</div>
    <div class="dt" data-t="t" onclick="setTab('lm','t')">DOT</div>
  </div>
  <div class="dtf on" id="lm-dtf-n">
    <div class="mg"><div><label>Flat Damage <span style="color:var(--muted)">(empty=advanced)</span></label><input type="number" id="lm-flat-n" min="0" placeholder="optional"></div></div>
    <button class="adv-btn" id="lm-advbtn-n" onclick="toggleAdv('lm','n')">▶ ADVANCED DMG</button>
    <div class="adv-fields" id="lm-adv-n"><div class="adv-note">Stat × (Mult/100) × (1+B1/100) × (1+B2/100)</div>
    <div class="mg">
      <div><label>Stat (bonus)</label><input type="number" id="lm-stat-n" min="0" placeholder="0" oninput="updAdv('lm','n')"></div>
      <div><label>Multiplier %</label><input type="number" id="lm-mult-n" min="0" placeholder="e.g. 160" oninput="updAdv('lm','n')"></div>
      <div><label>Buff 1 %</label><input type="number" id="lm-b1-n" min="0" placeholder="0" oninput="updAdv('lm','n')"></div>
      <div><label>Buff 2 %</label><input type="number" id="lm-b2-n" min="0" placeholder="0" oninput="updAdv('lm','n')"></div>
      <div class="full"><div class="adv-prev" id="lm-prev-n"></div></div>
    </div></div>
  </div>
  <div class="dtf" id="lm-dtf-d">
    <div class="mg">
      <div><label>Flat Damage <span style="color:var(--muted)">(empty=advanced)</span></label><input type="number" id="lm-flat-d" min="0" placeholder="optional"></div>
      <div><label>Delay (s)</label><input type="number" id="lm-delay" min="0" step="0.1" placeholder="e.g. 3"></div>
    </div>
    <button class="adv-btn" id="lm-advbtn-d" onclick="toggleAdv('lm','d')">▶ ADVANCED DMG</button>
    <div class="adv-fields" id="lm-adv-d"><div class="adv-note">Stat × (Mult/100) × (1+B1/100) × (1+B2/100)</div>
    <div class="mg">
      <div><label>Stat (bonus)</label><input type="number" id="lm-stat-d" min="0" placeholder="0" oninput="updAdv('lm','d')"></div>
      <div><label>Multiplier %</label><input type="number" id="lm-mult-d" min="0" placeholder="e.g. 160" oninput="updAdv('lm','d')"></div>
      <div><label>Buff 1 %</label><input type="number" id="lm-b1-d" min="0" placeholder="0" oninput="updAdv('lm','d')"></div>
      <div><label>Buff 2 %</label><input type="number" id="lm-b2-d" min="0" placeholder="0" oninput="updAdv('lm','d')"></div>
      <div class="full"><div class="adv-prev" id="lm-prev-d"></div></div>
    </div></div>
  </div>
  <div class="dtf" id="lm-dtf-t">
    <div class="mg">
      <div><label>Flat/tick <span style="color:var(--muted)">(empty=advanced)</span></label><input type="number" id="lm-flat-t" min="0" placeholder="optional"></div>
      <div><label>Tick every (s)</label><input type="number" id="lm-ticki" min="0.1" step="0.1" placeholder="e.g. 2" oninput="updDotPrev('lm')"></div>
      <div><label>Duration (s)</label><input type="number" id="lm-tickd" min="0" step="0.1" placeholder="e.g. 4" oninput="updDotPrev('lm')"></div>
      <div style="display:flex;align-items:flex-end"><div id="lm-dot-prev" style="font-family:var(--mono);font-size:11px;color:var(--muted);padding-bottom:8px"></div></div>
    </div>
    <button class="adv-btn" id="lm-advbtn-t" onclick="toggleAdv('lm','t')">▶ ADVANCED DMG (per tick)</button>
    <div class="adv-fields" id="lm-adv-t"><div class="adv-note">Stat × (Mult/100) × (1+B1/100) × (1+B2/100) per tick</div>
    <div class="mg">
      <div><label>Stat (bonus)</label><input type="number" id="lm-stat-t" min="0" placeholder="0" oninput="updAdv('lm','t')"></div>
      <div><label>Multiplier %</label><input type="number" id="lm-mult-t" min="0" placeholder="e.g. 160" oninput="updAdv('lm','t')"></div>
      <div><label>Buff 1 %</label><input type="number" id="lm-b1-t" min="0" placeholder="0" oninput="updAdv('lm','t')"></div>
      <div><label>Buff 2 %</label><input type="number" id="lm-b2-t" min="0" placeholder="0" oninput="updAdv('lm','t')"></div>
      <div class="full"><div class="adv-prev" id="lm-prev-t"></div></div>
    </div></div>
  </div>
  <hr class="sdiv"><div class="slbl">Effect (optional)</div>
  <div class="mg">
    <div><label>Effect Name</label><input type="text" id="lm-effn" placeholder="e.g. Bleed"></div>
    <div><label>Effect Duration (s)</label><input type="number" id="lm-effd" min="0" step="0.1" placeholder="0"></div>
    <div class="full"><div class="cb-row"><input type="checkbox" id="lm-stacks"><label for="lm-stacks">Effect stacks on reuse (unchecked = refresh)</label></div></div>
  </div>
  <hr class="sdiv"><div class="slbl">Stun Damage (optional)</div>
  <div class="mg">
    <div><label>Stun Meter Damage</label><input type="number" id="lm-stundmg" min="0" placeholder="0"></div>
  </div>
  <div class="ma">
    <button class="btn btn-y" id="lm-ok" onclick="confirmLog()">CONFIRM</button>
    <button class="btn btn-gh" onclick="closeOv('ov-log')">CANCEL</button>
  </div>
</div>
</div>

<!-- ABILITY EDITOR MODAL -->
<div class="ov" id="ov-ae">
<div class="mbox">
  <h2 id="ae-title">ADD ABILITY</h2>
  <div id="ae-stat-hint" style="display:none;font-family:var(--mono);font-size:11px;color:var(--yd);margin-bottom:14px">CHAR BASE STAT: <span id="ae-stat-val">0</span> — Stat field = bonus on top</div>
  <div id="ae-var-row" style="display:none;margin-bottom:12px">
    <div class="flbl">Variant Tag <span style="color:var(--muted)">(e.g. Hold, Enhanced, Charged)</span></div>
    <input type="text" id="ae-vartag" placeholder="e.g. Hold">
  </div>
  <div class="mg">
    <div class="full"><label>Ability Name</label><input type="text" id="ae-name" placeholder="e.g. Fireball"></div>
    <div class="full"><label>Description</label><textarea id="ae-desc"></textarea></div>
    <div><label>Cast Time (s)</label><input type="number" id="ae-cast" min="0" step="0.1" placeholder="0"></div>
    <div><label>Cooldown (s)</label><input type="number" id="ae-cd" min="0" step="0.1" placeholder="0"></div>
    <div class="full"><label>Hit Type</label><select id="ae-hit"><option value="single">Single Target</option><option value="multi">Multi Hit (all enemies)</option></select></div>
  </div>
  <hr class="sdiv"><div class="slbl">Damage Type</div>
  <div class="dtt" id="ae-tabs">
    <div class="dt on" data-t="n" onclick="setTab('ae','n')">NORMAL</div>
    <div class="dt" data-t="d" onclick="setTab('ae','d')">DELAYED</div>
    <div class="dt" data-t="t" onclick="setTab('ae','t')">DOT</div>
  </div>
  <div class="dtf on" id="ae-dtf-n">
    <div class="mg"><div><label>Flat Damage <span style="color:var(--muted)">(empty=advanced)</span></label><input type="number" id="ae-flat-n" min="0" placeholder="optional"></div></div>
    <button class="adv-btn" id="ae-advbtn-n" onclick="toggleAdv('ae','n')">▶ ADVANCED DMG</button>
    <div class="adv-fields" id="ae-adv-n"><div class="adv-note">Stat × (Mult/100) × (1+B1/100) × (1+B2/100)</div>
    <div class="mg">
      <div><label>Stat (bonus)</label><input type="number" id="ae-stat-n" min="0" placeholder="0" oninput="updAdv('ae','n')"></div>
      <div><label>Multiplier %</label><input type="number" id="ae-mult-n" min="0" placeholder="e.g. 160" oninput="updAdv('ae','n')"></div>
      <div><label>Buff 1 %</label><input type="number" id="ae-b1-n" min="0" placeholder="0" oninput="updAdv('ae','n')"></div>
      <div><label>Buff 2 %</label><input type="number" id="ae-b2-n" min="0" placeholder="0" oninput="updAdv('ae','n')"></div>
      <div class="full"><div class="adv-prev" id="ae-prev-n"></div></div>
    </div></div>
  </div>
  <div class="dtf" id="ae-dtf-d">
    <div class="mg">
      <div><label>Flat Damage <span style="color:var(--muted)">(empty=advanced)</span></label><input type="number" id="ae-flat-d" min="0" placeholder="optional"></div>
      <div><label>Delay (s)</label><input type="number" id="ae-delay" min="0" step="0.1" placeholder="e.g. 3"></div>
    </div>
    <button class="adv-btn" id="ae-advbtn-d" onclick="toggleAdv('ae','d')">▶ ADVANCED DMG</button>
    <div class="adv-fields" id="ae-adv-d"><div class="adv-note">Stat × (Mult/100) × (1+B1/100) × (1+B2/100)</div>
    <div class="mg">
      <div><label>Stat (bonus)</label><input type="number" id="ae-stat-d" min="0" placeholder="0" oninput="updAdv('ae','d')"></div>
      <div><label>Multiplier %</label><input type="number" id="ae-mult-d" min="0" placeholder="e.g. 160" oninput="updAdv('ae','d')"></div>
      <div><label>Buff 1 %</label><input type="number" id="ae-b1-d" min="0" placeholder="0" oninput="updAdv('ae','d')"></div>
      <div><label>Buff 2 %</label><input type="number" id="ae-b2-d" min="0" placeholder="0" oninput="updAdv('ae','d')"></div>
      <div class="full"><div class="adv-prev" id="ae-prev-d"></div></div>
    </div></div>
  </div>
  <div class="dtf" id="ae-dtf-t">
    <div class="mg">
      <div><label>Flat/tick <span style="color:var(--muted)">(empty=advanced)</span></label><input type="number" id="ae-flat-t" min="0" placeholder="optional"></div>
      <div><label>Tick every (s)</label><input type="number" id="ae-ticki" min="0.1" step="0.1" placeholder="e.g. 2" oninput="updDotPrev('ae')"></div>
      <div><label>Duration (s)</label><input type="number" id="ae-tickd" min="0" step="0.1" placeholder="e.g. 4" oninput="updDotPrev('ae')"></div>
      <div style="display:flex;align-items:flex-end"><div id="ae-dot-prev" style="font-family:var(--mono);font-size:11px;color:var(--muted);padding-bottom:8px"></div></div>
    </div>
    <button class="adv-btn" id="ae-advbtn-t" onclick="toggleAdv('ae','t')">▶ ADVANCED DMG (per tick)</button>
    <div class="adv-fields" id="ae-adv-t"><div class="adv-note">per tick</div>
    <div class="mg">
      <div><label>Stat (bonus)</label><input type="number" id="ae-stat-t" min="0" placeholder="0" oninput="updAdv('ae','t')"></div>
      <div><label>Multiplier %</label><input type="number" id="ae-mult-t" min="0" placeholder="e.g. 160" oninput="updAdv('ae','t')"></div>
      <div><label>Buff 1 %</label><input type="number" id="ae-b1-t" min="0" placeholder="0" oninput="updAdv('ae','t')"></div>
      <div><label>Buff 2 %</label><input type="number" id="ae-b2-t" min="0" placeholder="0" oninput="updAdv('ae','t')"></div>
      <div class="full"><div class="adv-prev" id="ae-prev-t"></div></div>
    </div></div>
  </div>
