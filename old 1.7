let eeIdx=null; // index into bEnemies being edited

function openEnemyEditor(idx){
  if(bEnemies[idx]?.hp<=0)return; // don't edit dead enemies
  eeIdx=idx;
  const e=bEnemies[idx];
  document.getElementById('ee-title').textContent='EDIT: '+e.name.toUpperCase();
  document.getElementById('ee-hp').value=e.hp;
  document.getElementById('ee-res').value=e.res??'';
  document.getElementById('ee-sres').value=e.sRes??'';
  document.getElementById('ee-smmax').value=e.stunMax??'';
  document.getElementById('ee-sdur').value=e.stunDur??'';
  openOv('ov-enemy');
}

function saveEnemyEdit(){
  const e=bEnemies[eeIdx];if(!e)return;
  const newHp=parseInt(document.getElementById('ee-hp').value);
  e.hp=Math.max(0,Math.min(e.maxHp,isNaN(newHp)?e.hp:newHp));
  const resRaw=document.getElementById('ee-res').value;
  const sResRaw=document.getElementById('ee-sres').value;
  e.res=resRaw!==''?parseFloat(resRaw):null;
  e.sRes=sResRaw!==''?parseFloat(sResRaw):null;
  const smRaw=document.getElementById('ee-smmax').value;
  const sdRaw=document.getElementById('ee-sdur').value;
  const newMax=smRaw!==''?parseFloat(smRaw):null;
  // If stun meter newly set, init current meter
  if(newMax!=null&&e.stunMax==null)e.stunCur=newMax;
  else if(newMax!=null)e.stunCur=Math.min(e.stunCur??newMax,newMax);
  e.stunMax=newMax;
  e.stunDur=sdRaw!==''?parseFloat(sdRaw):null;
  closeOv('ov-enemy');
  renderBattle();
}

// Get active resistance for an enemy
function getEnemyRes(e){
  if(isEnemyStunned(e))return e.sRes??0;
  return e.res??0;
}

// Is enemy currently stunned?
function isEnemyStunned(e){
  if(!e.stunStart&&e.stunStart!==0)return false;
  const elapsed=logTotalTime(bLog)-e.stunStart;
  return elapsed<(e.stunDur||0);
}

// Remaining stun duration
function stunRemaining(e){
  if(!isEnemyStunned(e))return 0;
  return Math.max(0,(e.stunDur||0)-(logTotalTime(bLog)-e.stunStart));
}

// Apply stun damage to an enemy (only if not already stunned)
function applyStunDmg(e,stunDmg){
  if(!e.stunMax||e.stunDur==null||stunDmg<=0)return;
  if(isEnemyStunned(e))return; // already stunned, ignore
  e.stunCur=Math.max(0,(e.stunCur??e.stunMax)-stunDmg);
  if(e.stunCur<=0){
    // Trigger stun
    e.stunStart=logTotalTime(bLog);
    e.stunCur=0;
  }
}

// After recalc, check if any stun durations have expired and reset them
function checkStunExpiry(){
  const tt=logTotalTime(bLog);
  bEnemies.forEach(e=>{
    if(e.stunStart==null)return;
    if(tt-e.stunStart>=(e.stunDur||0)){
      // Stun expired — reset
      e.stunStart=null;
      e.stunCur=e.stunMax;
    }
  });
}

// Apply resistance to damage value
function applyResistance(rawDmg,e){
  const res=getEnemyRes(e);
  if(!res)return rawDmg;
  return Math.round(rawDmg*(1-res/100));
}

